---
import { PRODUCT_CATEGORIES } from '../data/productCatalog.js';
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';

const currentPath = new URL(Astro.request.url).pathname;
const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.productDefault)}`;

const navigation = [
  { name: 'Teknologi', href: '/#technology-support' },
  { name: 'Cara kerja', href: '/#workflow' },
  { name: 'Portfolio', href: '/portfolio/' },
  { name: 'Blog', href: '/blog/' }
];
---

<header id="main-header" class="group fixed inset-x-0 top-0 z-40 h-[76px] border-b border-white/10 bg-background/75 backdrop-blur-xl transition-all duration-500">
  <div class="container-custom flex h-full items-center justify-between gap-8">
    <a href="/" class="group/brand flex min-w-fit items-center gap-3" aria-label="Raja Cutting Laser — Beranda">
      <img src="/images/logo.webp" alt="Logo Raja Cutting Laser" class="h-9 w-9 object-contain transition-transform duration-300 group-hover/brand:scale-105" />
      <span class="leading-none">
        <strong class="block text-[0.82rem] font-extrabold uppercase tracking-[0.13em] text-text-main">Raja Cutting</strong>
        <span class="mt-1 block font-mono text-[0.55rem] uppercase tracking-[0.24em] text-text-secondary">Laser atelier</span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Navigasi utama">
      <div class="relative" data-products-root>
        <button
          type="button"
          class:list={[
            'flex items-center gap-2 py-3 text-sm font-semibold text-text-secondary transition-colors hover:text-text-main',
            currentPath.startsWith('/produk/') && 'text-text-main'
          ]}
          aria-expanded="false"
          aria-controls="product-mega-menu"
          data-products-trigger
        >
          Produk
          <svg class="h-3.5 w-3.5 transition-transform duration-300" data-chevron fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="m6 9 6 6 6-6" />
          </svg>
        </button>

        <div id="product-mega-menu" class="invisible fixed left-1/2 top-[76px] w-[min(900px,calc(100vw-3rem))] -translate-x-1/2 translate-y-2 border border-white/10 bg-[#111412]/[0.98] p-3 opacity-0 shadow-2xl backdrop-blur-xl transition-all duration-300" data-products-menu>
          <div class="grid grid-cols-3">
            {PRODUCT_CATEGORIES.map((product) => (
              <a href={product.href} class="group/item flex min-h-[108px] gap-4 border border-transparent p-4 transition-colors hover:border-white/10 hover:bg-white/[0.035]">
                <span class="font-mono text-[0.6rem] text-accent">{product.number}</span>
                <span>
                  <strong class="block text-sm font-bold leading-snug text-text-main group-hover/item:text-accent">{product.name}</strong>
                  <span class="mt-2 block font-mono text-[0.58rem] uppercase tracking-[0.1em] text-text-secondary">{product.technology}</span>
                </span>
              </a>
            ))}
          </div>
          <div class="mt-3 flex items-center justify-between border-t border-white/10 px-4 pt-4">
            <p class="font-mono text-[0.58rem] uppercase tracking-[0.14em] text-text-secondary">9 aplikasi · 4 teknologi produksi</p>
            <a href="/#products" class="link-arrow text-xs">Lihat seluruh katalog
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M5 12h14m-5-5 5 5-5 5" /></svg>
            </a>
          </div>
        </div>
      </div>

      {navigation.map((item) => (
        <a
          href={item.href}
          class:list={[
            'py-3 text-sm font-semibold text-text-secondary transition-colors hover:text-text-main',
            currentPath === item.href && 'text-text-main'
          ]}
        >{item.name}</a>
      ))}
    </nav>

    <div class="hidden items-center gap-5 lg:flex">
      <a href={`tel:${SITE_CONFIG.phone}`} class="font-mono text-[0.62rem] uppercase tracking-[0.12em] text-text-secondary transition-colors hover:text-text-main">{SITE_CONFIG.phone}</a>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="button-primary px-5 py-2.5">
        Mulai proyek
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m-5-5 5 5-5 5" /></svg>
      </a>
    </div>

    <button type="button" class="grid h-11 w-11 place-items-center border border-white/15 text-text-main lg:hidden" aria-label="Buka menu" aria-expanded="false" aria-controls="mobile-menu" data-mobile-trigger>
      <span class="relative h-4 w-5" aria-hidden="true">
        <span class="absolute left-0 top-1 block h-px w-5 bg-current transition-all" data-menu-line="1"></span>
        <span class="absolute bottom-1 left-0 block h-px w-5 bg-current transition-all" data-menu-line="2"></span>
      </span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="invisible fixed inset-0 z-30 translate-y-[-1rem] overflow-y-auto bg-background pb-10 pt-[100px] opacity-0 transition-all duration-300 lg:hidden" data-mobile-menu>
  <div class="container-custom">
    <p class="eyebrow mb-7">Katalog produk</p>
    <div class="grid grid-cols-1 border-t border-white/10 sm:grid-cols-2">
      {PRODUCT_CATEGORIES.map((product) => (
        <a href={product.href} class="group flex items-center gap-5 border-b border-white/10 py-5 sm:odd:pr-5 sm:even:border-l sm:even:pl-5">
          <span class="font-mono text-[0.62rem] text-accent">{product.number}</span>
          <span class="text-base font-bold text-text-main group-hover:text-accent">{product.name}</span>
        </a>
      ))}
    </div>

    <nav class="mt-10 grid grid-cols-2 gap-x-5 border-t border-white/10" aria-label="Navigasi mobile">
      {navigation.map((item) => <a href={item.href} class="border-b border-white/10 py-5 text-sm font-semibold text-text-secondary">{item.name}</a>)}
      <a href="/about/" class="border-b border-white/10 py-5 text-sm font-semibold text-text-secondary">Tentang</a>
      <a href="/contact/" class="border-b border-white/10 py-5 text-sm font-semibold text-text-secondary">Kontak</a>
    </nav>

    <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="button-primary mt-9 w-full">Konsultasi via WhatsApp</a>
  </div>
</div>

<script>
  const header = document.querySelector<HTMLElement>('#main-header');
  const productRoot = document.querySelector<HTMLElement>('[data-products-root]');
  const productTrigger = document.querySelector<HTMLButtonElement>('[data-products-trigger]');
  const productMenu = document.querySelector<HTMLElement>('[data-products-menu]');
  const chevron = document.querySelector<HTMLElement>('[data-chevron]');
  const mobileTrigger = document.querySelector<HTMLButtonElement>('[data-mobile-trigger]');
  const mobileMenu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const menuLines = document.querySelectorAll<HTMLElement>('[data-menu-line]');

  const setProductsOpen = (open: boolean) => {
    productTrigger?.setAttribute('aria-expanded', String(open));
    productMenu?.classList.toggle('invisible', !open);
    productMenu?.classList.toggle('opacity-0', !open);
    productMenu?.classList.toggle('translate-y-2', !open);
    chevron?.classList.toggle('rotate-180', open);
  };

  productTrigger?.addEventListener('click', () => setProductsOpen(productTrigger.getAttribute('aria-expanded') !== 'true'));
  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Node) || productRoot?.contains(event.target)) return;
    setProductsOpen(false);
  });

  const setMobileOpen = (open: boolean) => {
    mobileTrigger?.setAttribute('aria-expanded', String(open));
    mobileTrigger?.setAttribute('aria-label', open ? 'Tutup menu' : 'Buka menu');
    mobileMenu?.classList.toggle('invisible', !open);
    mobileMenu?.classList.toggle('opacity-0', !open);
    mobileMenu?.classList.toggle('translate-y-[-1rem]', !open);
    document.body.classList.toggle('overflow-hidden', open);
    menuLines[0]?.classList.toggle('rotate-45', open);
    menuLines[0]?.classList.toggle('top-[7px]', open);
    menuLines[1]?.classList.toggle('-rotate-45', open);
    menuLines[1]?.classList.toggle('bottom-[8px]', open);
  };

  mobileTrigger?.addEventListener('click', () => setMobileOpen(mobileTrigger.getAttribute('aria-expanded') !== 'true'));
  mobileMenu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMobileOpen(false)));

  const updateHeader = () => header?.classList.toggle('shadow-[0_18px_60px_rgba(0,0,0,0.24)]', window.scrollY > 16);
  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>
