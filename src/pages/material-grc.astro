---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { MATERIALS, SERVICES } from '../utils/constants.js';
import OptimizedImage from '../components/OptimizedImage.astro';

import { generateMetaTags, generateServiceSchema, generateBreadcrumbSchema } from '../utils/seo.ts';

// Find GRC material with proper error handling
const material = MATERIALS.find(m => m.id === 'grc');
if (!material) {
    throw new Error('Material GRC not found');
}

const recommendedService = SERVICES.find(s => s.id === 'cnc-router');
if (!recommendedService) throw new Error('Recommended service not found');

// Generate Meta Tags with proper typing
const metaTags = generateMetaTags({
  title: `${material.name} - Material Laser Cutting Premium`,
  description: material.description,
  keywords: material.keywords,
  image: material.image,
  type: 'article'
});

// Generate structured data
const serviceSchema = recommendedService ? generateServiceSchema(recommendedService) : null;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Beranda', url: '/' },
  { name: 'Material', url: '/#materials' },
  { name: material.name, url: `/material-grc/` }
]);

// Combine schemas for jsonLd
const jsonLd = [serviceSchema, breadcrumbSchema].filter(Boolean);

---

<BaseLayout 
  title={`${material.name} - Material Laser Cutting Premium`}
  description={material.description}
  keywords={material.keywords}
  image={material.image}
  jsonLd={jsonLd}
>
  <Header slot="header" />
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-background via-container to-background text-text-main py-20">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl lg:text-5xl font-bold mb-6">
            raja cutting laser {material.name}
          </h1>
          <p class="text-xl mb-8 text-text-secondary">
            {material.description}
          </p>
          <div class="flex flex-wrap gap-4">
            <a 
              href={`https://api.whatsapp.com/send?phone=6285165693179&text=Halo%20raja%20cutting%20laser,%20saya%20ingin%20konsultasi%20dong%20tentang%20jasa%20laser%20cutting%20${material.name}.%20Bisa%20konsultasi?`}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-button hover:bg-highlight text-white hover:text-button px-8 py-3 rounded-lg font-semibold transition-colors"
            >
              Konsultasi Gratis
            </a>
            <a 
              href="contact" 
              class="border-2 border-button text-button hover:bg-button hover:text-white px-8 py-3 rounded-lg font-semibold transition-colors"
            >
              Request Quote
            </a>
          </div>
        </div>
        <div class="relative">
          <OptimizedImage 
            src={material.image} 
            alt={`Sample ${material.name}`}
            className="w-full h-96 object-cover rounded-lg shadow-2xl"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Material Characteristics -->
  <section class="py-16 bg-container">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-text-main mb-4">
          Karakteristik {material.name}
        </h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          Cutting GRC (Glassfibre Reinforced Concrete) untuk fasad dan ornamen bangunan
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-background p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-container rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-text-main">Sangat Kuat</h3>
          <p class="text-text-secondary">Memiliki kekuatan tekan dan tarik yang sangat tinggi, cocok untuk elemen struktural.</p>
        </div>

        <div class="bg-background p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-container rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-text-main">Tahan Api</h3>
          <p class="text-text-secondary">Material yang tidak mudah terbakar, memberikan keamanan lebih pada bangunan.</p>
        </div>

        <div class="bg-background p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-container rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-text-main">Fleksibel</h3>
          <p class="text-text-secondary">Dapat dicetak menjadi berbagai bentuk ornamen yang rumit dan detail.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Specifications -->
  <section class="py-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-text-main mb-6">
            Spesifikasi Teknis
          </h2>
          <div class="space-y-4">
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Ketebalan</span>
              <span class="text-text-secondary">{material.thickness}</span>
            </div>
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Ukuran Standard</span>
              <span class="text-text-secondary">Custom Sesuai Kebutuhan</span>
            </div>
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Metode Cutting</span>
              <span class="text-text-secondary">CNC Router</span>
            </div>
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Finishing</span>
              <span class="text-text-secondary">Halus (Cat-able)</span>
            </div>
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Warna Tersedia</span>
              <span class="text-text-secondary">Abu-abu Natural (Dapat Dicat)</span>
            </div>
          </div>
        </div>
        <div class="bg-container p-8 rounded-lg">
          <h3 class="text-2xl font-bold text-text-main mb-6">Contoh Aplikasi</h3>
          <div class="grid grid-cols-2 gap-4">
            <OptimizedImage src="/images/grcpro (1).webp" alt="Contoh Aplikasi 1" className="w-full h-40 object-cover rounded-lg shadow-md" />
            <OptimizedImage src="/images/grcpro (2).webp" alt="Contoh Aplikasi 2" className="w-full h-40 object-cover rounded-lg shadow-md" />
            <OptimizedImage src="/images/grcpro (3).webp" alt="Contoh Aplikasi 3" className="w-full h-40 object-cover rounded-lg shadow-md" />
            <OptimizedImage src="/images/grcpro (4).webp" alt="Contoh Aplikasi 4" className="w-full h-40 object-cover rounded-lg shadow-md" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recommended Service -->
  <section class="py-16 bg-container">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-text-main mb-4">
          Mesin Rekomendasi untuk {material.name}
        </h2>
        <p class="text-xl text-text-secondary">
          Teknologi CNC Router untuk hasil cutting presisi pada material GRC
        </p>
      </div>

      <div class="bg-background rounded-lg shadow-lg p-8">
        <div class="grid lg:grid-cols-2 gap-8 items-center">
          <div>
            <h3 class="text-2xl font-bold text-text-main mb-4">
              {recommendedService.name}
            </h3>
            <p class="text-text-secondary mb-6">
              {recommendedService.description}
            </p>
            <div class="space-y-3">
              {recommendedService.features.map((feature) => (
                <div class="flex items-center space-x-3">
                  <svg class="w-5 h-5 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-text-secondary">{feature}</span>
                </div>
              ))}
            </div>
            <div class="mt-6">
              <span class="text-2xl font-bold text-button">Hubungi Kami</span>
            </div>
          </div>
          <div>
            <OptimizedImage 
              src={recommendedService.image} 
              alt={recommendedService.name}
              className="w-full h-64 object-cover rounded-lg"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-r from-button to-primary text-white">
    <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-4">
        Siap Memulai Project {material.name} Anda?
      </h2>
      <p class="text-xl mb-8 text-text-secondary">
        Konsultasikan kebutuhan cutting Anda dengan tim ahli kami. Gratis estimasi dan saran teknis.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href={`https://api.whatsapp.com/send?phone=6285165693179&text=Halo%20raja%20cutting%20laser,%20saya%20ingin%20konsultasi%20dong%20tentang%20jasa%20laser%20cutting%20${material.name}.%20Bisa%20konsultasi?`}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-button hover:bg-highlight text-white hover:text-button px-8 py-3 rounded-lg font-semibold transition-colors inline-flex items-center justify-center"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/>
          </svg>
          Chat WhatsApp
        </a>
        <a 
          href="contact" 
          class="border-2 border-button text-button hover:bg-button hover:text-white px-8 py-3 rounded-lg font-semibold transition-colors"
        >
          Request Quote Detail
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
