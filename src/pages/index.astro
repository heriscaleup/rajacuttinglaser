---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import OptimizedImage from '../components/OptimizedImage.astro';

import {
  PRODUCT_CATEGORIES,
  PRODUCT_FAQ,
  PRODUCT_REASONS,
  PRODUCT_WORKFLOW,
  SERVICES,
  PORTFOLIO,
  SITE_CONFIG,
  WHATSAPP_MESSAGES
} from '../utils/constants.js';

import { generateMetaTags, generateFAQSchema } from '../utils/seo.ts';

const metaTags = generateMetaTags({
  title: "Produsen Produk Laser Cutting Custom Tangerang Selatan",
  description: "Raja Cutting Laser memproduksi pagar laser cutting, railing balkon, partisi ruangan, huruf timbul, mihrab, dan plafon dekoratif custom untuk rumah, kantor, toko, dan proyek komersial di Tangerang Selatan dan sekitarnya.",
  keywords: "produsen produk laser cutting, pagar laser cutting tangerang selatan, railing balkon laser cutting, partisi ruangan laser cutting, huruf timbul tangsel, mihrab laser cutting, plafon dekoratif laser cutting",
  url: "/",
  type: "website",
  image: "/images/stainlesssteel.webp",
  modifiedTime: "2026-04-23T00:00:00+07:00",
  author: SITE_CONFIG.author
});

const faqSchema = generateFAQSchema(PRODUCT_FAQ);
const featuredPortfolio = PORTFOLIO.slice(0, 6);
---

<BaseLayout metaTags={metaTags} jsonLd={[faqSchema]}>
  <Header slot="header" />

  <Hero
    title="Produsen Produk Laser Cutting Custom untuk Rumah, Kantor, dan Proyek Komersial"
    subtitle="Pagar, railing balkon, partisi ruangan, huruf timbul, mihrab, dan panel dekoratif"
    description="Raja Cutting Laser membantu kebutuhan produk custom berbasis laser cutting di Tangerang Selatan dan sekitarnya. Fokus kami bukan hanya proses cutting material, tetapi hasil jadi yang siap dipakai untuk fasad, interior, signage, dan elemen dekoratif proyek Anda."
    primaryCTA="Konsultasi Desain & Harga"
    secondaryCTA="Lihat Produk Prioritas"
    secondaryCTALink="/#products"
    backgroundImage="/images/stainlesssteel.webp"
    whatsappMessage={WHATSAPP_MESSAGES.productDefault}
  />

  <section id="products" class="section-padding bg-background cv-auto">
    <div class="container-custom">
      <div class="text-center mb-20">
        <div class="inline-flex items-center px-6 py-3 bg-button/10 border border-button/20 rounded-full text-button font-semibold text-sm mb-6">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
          </svg>
          Produk Prioritas
        </div>
        <h2 class="heading-lg text-text-main mb-8">Produk Laser Cutting yang Paling Sering Diminta</h2>
        <p class="text-xl text-text-secondary max-w-4xl mx-auto leading-relaxed">
          Website ini kami arahkan khusus untuk kebutuhan produk jadi dan aplikasi laser cutting. Cocok untuk Anda yang mencari solusi pagar, railing, partisi, huruf timbul, atau panel dekoratif custom.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
        {PRODUCT_CATEGORIES.map((product) => {
          const isDetailPage = product.href.startsWith('/produk/');
          return (
            <article class="group bg-container rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 overflow-hidden border border-primary/50 flex flex-col">
              <div class="relative overflow-hidden">
                <OptimizedImage
                  src={product.image}
                  alt={product.name}
                  className="w-full h-60 object-cover group-hover:scale-110 transition-transform duration-700"
                  loading="lazy"
                  width={640}
                  height={400}
                />
                <div class="absolute inset-0 bg-gradient-to-t from-background/80 via-background/20 to-transparent"></div>
                <div class="absolute top-4 left-4 rounded-full bg-container/90 px-3 py-1 text-xs font-semibold text-text-main shadow-lg">
                  {product.audience}
                </div>
              </div>

              <div class="p-8 flex flex-col flex-grow">
                <h3 class="text-2xl font-bold text-text-main mb-4 group-hover:text-button transition-colors duration-300">
                  {product.name}
                </h3>
                <p class="text-text-secondary leading-relaxed mb-6 flex-grow">
                  {product.description}
                </p>

                <div class="mb-6 space-y-3">
                  <div class="rounded-xl bg-background border border-primary/40 px-4 py-3">
                    <p class="text-xs uppercase tracking-wide text-text-secondary mb-1">Material Umum</p>
                    <p class="text-sm font-medium text-text-main">{product.material}</p>
                  </div>
                </div>

                <a
                  href={product.href}
                  class="inline-flex items-center justify-center w-full bg-button text-white font-semibold px-6 py-4 rounded-xl transition-all duration-300 hover:bg-primary hover:shadow-lg"
                >
                  <span class="flex items-center justify-center">
                    {isDetailPage ? 'Lihat Detail Produk' : 'Konsultasi Produk'}
                    <svg class="w-4 h-4 ml-2 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </span>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section id="why-us" class="section-padding bg-container cv-auto">
    <div class="container-custom">
      <div class="text-center mb-20">
        <div class="inline-flex items-center px-6 py-3 bg-primary/10 border border-primary/20 rounded-full text-primary font-semibold text-sm mb-6">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          Pendekatan Kerja
        </div>
        <h2 class="heading-lg text-text-main mb-8">Kenapa Website Ini Difokuskan ke Produk Jadi</h2>
        <p class="text-xl text-text-secondary max-w-4xl mx-auto leading-relaxed">
          Banyak calon klien tidak sedang mencari proses laser cutting mentah. Mereka mencari hasil akhirnya: panel pagar, railing, partisi, huruf timbul, atau elemen dekoratif yang siap masuk ke proyek.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
        {PRODUCT_REASONS.map((reason) => (
          <article class="rounded-2xl border border-primary/40 bg-background p-8 shadow-lg">
            <h3 class="text-xl font-bold text-text-main mb-4">{reason.title}</h3>
            <p class="text-text-secondary leading-relaxed">{reason.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="workflow" class="section-padding bg-background cv-auto">
    <div class="container-custom">
      <div class="text-center mb-20">
        <div class="inline-flex items-center px-6 py-3 bg-button/10 border border-button/20 rounded-full text-button font-semibold text-sm mb-6">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Alur Pengerjaan
        </div>
        <h2 class="heading-lg text-text-main mb-8">Dari Brief Sampai Produk Custom Siap Diproses</h2>
        <p class="text-xl text-text-secondary max-w-4xl mx-auto leading-relaxed">
          Alur ini kami pakai untuk memastikan desain, material, ukuran panel, dan hasil akhir tetap realistis saat diproduksi, bukan hanya bagus di referensi visual.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
        {PRODUCT_WORKFLOW.map((item) => (
          <article class="relative rounded-2xl border border-primary/40 bg-container p-8 shadow-lg">
            <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-full bg-button text-lg font-bold text-white">
              {item.step}
            </div>
            <h3 class="text-xl font-bold text-text-main mb-4">{item.title}</h3>
            <p class="text-text-secondary leading-relaxed">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="technology-support" class="section-padding bg-container cv-auto">
    <div class="container-custom">
      <div class="text-center mb-20">
        <div class="inline-flex items-center px-6 py-3 bg-primary/10 border border-primary/20 rounded-full text-primary font-semibold text-sm mb-6">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          Teknologi Produksi
        </div>
        <h2 class="heading-lg text-text-main mb-8">Produk Kami Dibuat dengan Teknologi yang Menyesuaikan Material</h2>
        <p class="text-xl text-text-secondary max-w-4xl mx-auto leading-relaxed">
          Walau website ini fokus ke produk jadi, proses produksinya tetap penting. Karena itu kami tetap tampilkan teknologi pendukung yang relevan untuk metal, acrylic, kayu, MDF, dan material dekoratif lain.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
        {SERVICES.map((service) => (
          <article class="rounded-2xl border border-primary/40 bg-background p-8 shadow-lg flex flex-col">
            <div class="mb-6">
              <OptimizedImage
                src={service.image}
                alt={service.name}
                className="h-44 w-full rounded-xl object-cover"
                loading="lazy"
                width={480}
                height={280}
              />
            </div>
            <h3 class="text-xl font-bold text-text-main mb-4">{service.name}</h3>
            <p class="text-text-secondary leading-relaxed mb-6 flex-grow">{service.description}</p>
            <a
              href={`/${service.slug}/`}
              class="inline-flex items-center font-semibold text-button hover:text-highlight transition-colors duration-300"
            >
              Pelajari Teknologinya
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="portfolio" class="section-padding bg-background cv-auto">
    <div class="container-custom">
      <div class="text-center mb-20">
        <div class="inline-flex items-center px-6 py-3 bg-button/10 border border-button/20 rounded-full text-button font-semibold text-sm mb-6">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"></path>
          </svg>
          Referensi Pengerjaan
        </div>
        <h2 class="heading-lg text-text-main mb-8">Contoh Pengerjaan Material dan Panel Custom</h2>
        <p class="text-xl text-text-secondary max-w-4xl mx-auto leading-relaxed">
          Sebagian proyek berangkat dari kebutuhan cutting material, sebagian lagi berkembang menjadi panel custom dan elemen produk. Referensi ini membantu calon klien melihat arah kualitas dan jenis aplikasi yang bisa kami kerjakan.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-8">
        {featuredPortfolio.map((project) => (
          <a href="/portfolio/" class="group rounded-2xl overflow-hidden border border-primary/40 bg-container shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
            <div class="relative overflow-hidden">
              <OptimizedImage
                src={project.image}
                alt={project.title}
                className="h-64 w-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                width={640}
                height={420}
              />
              <div class="absolute top-4 left-4 rounded-full bg-button px-3 py-1 text-xs font-semibold text-white">
                {project.category}
              </div>
            </div>
            <div class="p-8">
              <h3 class="text-xl font-bold text-text-main mb-3 group-hover:text-button transition-colors duration-300">
                {project.title}
              </h3>
              <p class="text-sm text-text-secondary mb-4">{project.material}</p>
              <p class="text-text-secondary leading-relaxed">{project.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="section-padding bg-container cv-auto">
    <div class="container-custom">
      <div class="text-center mb-20">
        <div class="inline-flex items-center px-6 py-3 bg-primary/10 border border-primary/20 rounded-full text-primary font-semibold text-sm mb-6">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01"></path>
          </svg>
          FAQ Produk
        </div>
        <h2 class="heading-lg text-text-main mb-8">Pertanyaan yang Paling Sering Muncul Sebelum Produksi</h2>
        <p class="text-xl text-text-secondary max-w-4xl mx-auto leading-relaxed">
          Kalau Anda masih ada di tahap cari referensi, bagian ini akan membantu membedakan kapan kebutuhan Anda masuk kategori jasa cutting biasa dan kapan lebih cocok masuk jalur produk custom.
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-6" data-faq-container>
        {PRODUCT_FAQ.map((faq) => (
          <div class="bg-background rounded-2xl shadow-lg border border-primary/50 overflow-hidden hover:shadow-xl transition-all duration-300">
            <button class="flex items-center justify-between w-full text-left p-8 group" data-faq-button>
              <h3 class="text-lg font-semibold text-text-main pr-6 group-hover:text-button transition-colors duration-300">
                {faq.question}
              </h3>
              <div class="flex-shrink-0 w-10 h-10 bg-container rounded-full flex items-center justify-center group-hover:bg-button transition-colors duration-300">
                <svg class="w-5 h-5 text-primary group-hover:text-white transition-all duration-300" data-faq-icon fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </div>
            </button>
            <div class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out" data-faq-answer>
              <div class="px-8 pb-8">
                <p class="text-text-secondary leading-relaxed">{faq.answer}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Butuh Produk Laser Cutting Custom untuk Proyek Anda?"
    description="Kirim foto referensi, ukuran area, atau brief kebutuhan Anda. Kami bantu arahkan desain, material, dan pendekatan produksi yang paling masuk akal untuk proyek rumah, kantor, toko, atau ruang ibadah."
    secondaryText="Hubungi Tim Kami"
    secondaryLink="/contact/"
    variant="gradient"
    whatsappMessage={WHATSAPP_MESSAGES.productDefault}
  />

  <Footer slot="footer" />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const faqContainer = document.querySelector('[data-faq-container]');
    if (!faqContainer) return;

    faqContainer.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;

      const button = event.target.closest('[data-faq-button]');
      if (!button) return;

      const answer = button.nextElementSibling;
      const icon = button.querySelector('[data-faq-icon]');
      const isExpanded = button.getAttribute('aria-expanded') === 'true';

      button.setAttribute('aria-expanded', String(!isExpanded));

      if (answer && answer instanceof HTMLElement) {
        answer.style.maxHeight = isExpanded ? '0' : `${answer.scrollHeight}px`;
      }

      if (icon) {
        icon.classList.toggle('rotate-180');
      }
    });
  });
</script>
