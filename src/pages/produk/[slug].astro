---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';

import { PRODUCT_CATEGORIES, PRODUCT_DETAIL_PAGES } from '../../data/productCatalog.js';
import { PRODUCT_WORKFLOW, SERVICES, SITE_CONFIG, WHATSAPP_MESSAGES } from '../../utils/constants.js';
import { generateBreadcrumbSchema, generateFAQSchema, generateMetaTags, generateServiceSchema } from '../../utils/seo.ts';

export function getStaticPaths() {
  return PRODUCT_DETAIL_PAGES.map((product) => ({ params: { slug: product.slug }, props: { product } }));
}

const { product } = Astro.props;
const supportingServices = SERVICES.filter((service) => product.supportServiceIds.includes(service.id));
const productIndex = PRODUCT_CATEGORIES.findIndex((item) => item.slug === product.slug);
const relatedProducts = [1, 2, 3].map((offset) => PRODUCT_CATEGORIES[(productIndex + offset) % PRODUCT_CATEGORIES.length]);
const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(product.whatsappMessage || WHATSAPP_MESSAGES.productDefault)}`;

const metaTags = generateMetaTags({
  title: product.metaTitle,
  description: product.metaDescription,
  keywords: product.keywords,
  image: product.image,
  url: `/produk/${product.slug}/`,
  type: 'service',
  modifiedTime: '2026-07-15T00:00:00+07:00',
  author: SITE_CONFIG.author
});

const faqSchema = generateFAQSchema(product.faqs);
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Beranda', url: '/' },
  { name: 'Produk', url: '/#products' },
  { name: product.name, url: `/produk/${product.slug}/` }
]);
const serviceSchema = generateServiceSchema({ name: `${product.name} Custom di Tangerang Selatan`, description: product.metaDescription, image: product.image });
---

<BaseLayout metaTags={metaTags} jsonLd={[faqSchema, breadcrumbSchema, serviceSchema]}>
  <Header slot="header" />

  <section class="relative overflow-hidden bg-background pb-14 pt-[116px] md:pb-20 md:pt-[148px]">
    <div class="pointer-events-none absolute inset-0 metal-grain" aria-hidden="true"></div>
    <div class="container-custom relative">
      <nav class="mb-12 font-mono text-[0.6rem] uppercase tracking-[0.13em] text-text-secondary" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2.5">
          <li><a href="/" class="transition-colors hover:text-accent">Beranda</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/#products" class="transition-colors hover:text-accent">Produk</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-text-main">{product.shortName}</li>
        </ol>
      </nav>

      <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-end xl:gap-20">
        <div data-reveal>
          <p class="eyebrow mb-7">{product.kicker}</p>
          <h1 class="display-xl">{product.name}</h1>
          <p class="mt-8 max-w-3xl text-base leading-relaxed text-text-main/72 md:text-lg">{product.summary}</p>

          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="button-primary px-7 py-4">
              Konsultasi produk
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m-5-5 5 5-5 5" /></svg>
            </a>
            <a href="#specification" class="button-ghost px-7 py-4">Lihat material & proses</a>
          </div>

          <div class="mt-12 flex flex-wrap gap-2 border-t border-white/10 pt-6">
            {supportingServices.map((service) => <span class="tag">{service.name}</span>)}
            <span class="tag">Custom per brief</span>
          </div>
        </div>

        <figure class="relative image-zoom" data-reveal>
          <div class="relative min-h-[520px] overflow-hidden border border-white/10 bg-surface md:min-h-[650px]">
            <OptimizedImage
              src={product.image}
              alt={`${product.name} custom sebagai referensi aplikasi`}
              className="absolute inset-0 h-full w-full object-cover"
              loading="eager"
              fetchpriority="high"
              width={1000}
              height={1100}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
            <figcaption class="absolute inset-x-0 bottom-0 p-6 md:p-8">
              <p class="font-mono text-[0.58rem] uppercase tracking-[0.15em] text-white/55">Target hasil</p>
              <p class="mt-3 max-w-lg text-lg font-semibold leading-snug text-white md:text-xl">{product.outcome}</p>
            </figcaption>
          </div>
          <span class="absolute -bottom-4 -left-4 grid h-16 w-16 place-items-center rounded-full bg-accent font-mono text-[0.68rem] font-bold text-white md:-left-8 md:h-20 md:w-20">{product.number}</span>
        </figure>
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-surface py-12 md:py-16">
    <div class="container-custom">
      <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-4" data-reveal>
        {product.highlights.map((item, index) => (
          <div class="border-l border-white/15 pl-5">
            <span class="font-mono text-[0.58rem] text-accent">0{index + 1}</span>
            <p class="mt-4 text-sm font-semibold leading-relaxed text-text-main">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="specification" class="section-padding bg-paper text-ink">
    <div class="container-custom">
      <div class="mb-14 grid gap-8 lg:grid-cols-[0.7fr_1.3fr] lg:gap-20" data-reveal>
        <p class="eyebrow text-ink/55">Fit before finish</p>
        <h2 class="font-display text-[clamp(2.7rem,5.2vw,5.8rem)] font-semibold leading-[0.95] tracking-[-0.06em] text-ink">Material dipilih untuk fungsi, bukan sekadar katalog warna.</h2>
      </div>

      <div class="grid gap-5 lg:grid-cols-[0.85fr_1.15fr]">
        <article class="border border-black/15 p-7 md:p-10" data-reveal>
          <p class="font-mono text-[0.6rem] uppercase tracking-[0.16em] text-ink/50">Produk ini cocok untuk</p>
          <ul class="mt-8 divide-y divide-black/15 border-t border-black/15">
            {product.idealFor.map((item, index) => (
              <li class="grid grid-cols-[2rem_1fr] gap-4 py-5 text-sm leading-relaxed text-ink/70">
                <span class="font-mono text-[0.58rem] text-accent">0{index + 1}</span><span>{item}</span>
              </li>
            ))}
          </ul>
        </article>

        <article class="border border-black/15 p-7 md:p-10" data-reveal>
          <p class="font-mono text-[0.6rem] uppercase tracking-[0.16em] text-ink/50">Material utama</p>
          <div class="mt-8 grid gap-4 sm:grid-cols-3">
            {product.materials.map((material) => (
              <div class="border border-black/15 p-5">
                <h3 class="text-lg font-bold tracking-[-0.025em] text-ink">{material.name}</h3>
                <p class="mt-4 text-sm leading-relaxed text-ink/60">{material.note}</p>
              </div>
            ))}
          </div>
          <div class="mt-8 border-t border-black/15 pt-6">
            <p class="mb-4 font-mono text-[0.58rem] uppercase tracking-[0.13em] text-ink/50">Opsi finishing umum</p>
            <div class="flex flex-wrap gap-2">
              {product.finishOptions.map((item) => <span class="rounded-full border border-black/20 px-3 py-1.5 text-xs font-semibold text-ink/70">{item}</span>)}
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section-padding overflow-hidden bg-background">
    <div class="container-custom">
      <div class="grid gap-14 lg:grid-cols-[0.68fr_1.32fr] lg:gap-20">
        <div data-reveal>
          <p class="eyebrow mb-6">Production stack</p>
          <h2 class="display-lg">Teknologi mengikuti bagian yang dikerjakan.</h2>
          <p class="mt-7 max-w-md text-base leading-relaxed">Satu produk dapat melewati lebih dari satu proses. Kami menyusun urutannya berdasarkan material, detail, volume, dan target permukaan.</p>
          <p class="mt-7 font-mono text-[0.58rem] uppercase leading-relaxed tracking-[0.13em]">Angka kapabilitas merupakan acuan. Hasil final dikonfirmasi setelah file dan material ditinjau.</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2" data-reveal>
          {supportingServices.map((service, index) => (
            <a href={`/${service.slug}/`} class="group surface-card flex min-h-[310px] flex-col p-7 md:p-8">
              <div class="flex items-start justify-between gap-6">
                <span class="font-mono text-[0.6rem] text-accent">0{index + 1}</span>
                <span class="grid h-10 w-10 place-items-center rounded-full border border-white/15 transition group-hover:border-accent group-hover:text-accent">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m-5-5 5 5-5 5" /></svg>
                </span>
              </div>
              <h3 class="mt-14 text-3xl font-semibold tracking-[-0.045em] text-text-main">{service.name}</h3>
              <p class="mt-4 text-sm leading-relaxed">{service.description}</p>
              <div class="mt-auto flex flex-wrap gap-2 pt-7">
                <span class="tag">{service.thickness}</span>
                <span class="tag">Acuan {service.tolerance}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding border-y border-white/10 bg-surface">
    <div class="container-custom">
      <div class="mb-14 grid gap-8 lg:grid-cols-[1fr_0.55fr] lg:items-end" data-reveal>
        <div>
          <p class="eyebrow mb-6">Alur pengerjaan</p>
          <h2 class="display-lg">Dari referensi menjadi spesifikasi produksi.</h2>
        </div>
        <p class="max-w-xl text-sm leading-relaxed lg:justify-self-end">Setiap tahap mengurangi asumsi sebelum material, mesin, dan finishing mulai digunakan.</p>
      </div>

      <ol class="grid border-l border-t border-white/10 sm:grid-cols-2 xl:grid-cols-4" data-reveal>
        {PRODUCT_WORKFLOW.map((item) => (
          <li class="min-h-[300px] border-b border-r border-white/10 p-7 md:p-8">
            <span class="font-mono text-[0.62rem] text-accent">{item.step}</span>
            <h3 class="mt-16 text-xl font-bold leading-tight tracking-[-0.03em] text-text-main">{item.title}</h3>
            <p class="mt-4 text-sm leading-relaxed">{item.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section-padding bg-background">
    <div class="container-custom">
      <div class="grid gap-14 lg:grid-cols-[0.72fr_1.28fr] lg:gap-20">
        <div data-reveal>
          <p class="eyebrow mb-6">FAQ produk</p>
          <h2 class="display-lg">Hal yang perlu jelas sebelum produksi.</h2>
        </div>
        <div class="border-t border-white/10" data-reveal>
          {product.faqs.map((faq, index) => (
            <details class="group border-b border-white/10">
              <summary class="flex list-none items-start justify-between gap-6 py-7 [&::-webkit-details-marker]:hidden">
                <span class="flex gap-5">
                  <span class="mt-1 font-mono text-[0.6rem] text-accent">0{index + 1}</span>
                  <span class="text-lg font-semibold leading-snug text-text-main md:text-xl">{faq.question}</span>
                </span>
                <span class="relative mt-1 h-6 w-6 flex-none">
                  <span class="absolute left-1/2 top-1/2 h-px w-4 -translate-x-1/2 bg-text-main"></span>
                  <span class="absolute left-1/2 top-1/2 h-4 w-px -translate-y-1/2 bg-text-main transition-transform group-open:rotate-90"></span>
                </span>
              </summary>
              <p class="max-w-2xl pb-8 pl-10 text-sm leading-relaxed md:text-base">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding border-t border-white/10 bg-surface">
    <div class="container-custom">
      <div class="mb-12 flex flex-col gap-6 md:flex-row md:items-end md:justify-between" data-reveal>
        <div>
          <p class="eyebrow mb-5">Produk terkait</p>
          <h2 class="display-md">Mungkin proyek Anda masuk ke sini.</h2>
        </div>
        <a href="/#products" class="link-arrow">Lihat semua produk
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m-5-5 5 5-5 5" /></svg>
        </a>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {relatedProducts.map((item) => (
          <a href={item.href} class="group surface-card image-zoom overflow-hidden" data-reveal>
            <div class="relative aspect-[4/3] overflow-hidden">
              <OptimizedImage src={item.image} alt={item.name} className="h-full w-full object-cover" loading="lazy" width={640} height={480} />
              <div class="absolute inset-0 bg-gradient-to-t from-black/55 to-transparent"></div>
              <span class="absolute left-5 top-5 tag text-white/75">{item.number}</span>
            </div>
            <div class="flex items-center justify-between gap-5 p-6">
              <div><h3 class="text-xl font-bold tracking-[-0.03em] text-text-main group-hover:text-accent">{item.name}</h3><p class="mt-2 font-mono text-[0.56rem] uppercase tracking-[0.12em]">{item.technology}</p></div>
              <svg class="h-4 w-4 flex-none text-text-main transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m-5-5 5 5-5 5" /></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title={`Mari bicarakan ${product.shortName.toLowerCase()} yang tepat untuk proyek Anda.`}
    description="Kirim ukuran, foto lokasi, jumlah, dan referensi visual. Informasi yang lengkap membantu kami memberi arah material serta estimasi yang lebih relevan."
    primaryText="Kirim brief proyek"
    secondaryText="Hubungi tim"
    secondaryLink="/contact/"
    variant="default"
    size="lg"
    whatsappMessage={product.whatsappMessage}
  />

  <Footer slot="footer" />
</BaseLayout>
