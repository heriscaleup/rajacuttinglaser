---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { getCollection, type CollectionEntry } from 'astro:content';
import { generateBlogPostSchema, generateBreadcrumbSchema } from '../../utils/seo';

export async function getStaticPaths() {
 const allPosts = await getCollection('blog');
 return allPosts.filter(post => !post.data.draft).map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post }: { post: CollectionEntry<'blog'> } = Astro.props;
const { Content, headings } = await post.render();
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
 .filter(p => p.data.category === post.data.category && p.slug !== post.slug && !p.data.draft)
 .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
 .slice(0, 3);

const siteName = 'Raja Cutting Laser';
const accent = 'text-accent';
const fallbackImage = '/images/metal.webp';
function resolveImage(image) {
 if (!image) return fallbackImage;
 if (image.startsWith('http://') || image.startsWith('https://')) return image;
 const normalized = image.startsWith('/') ? image : `/${image}`;
 return existsSync(join(process.cwd(), 'public', normalized.slice(1))) ? normalized : fallbackImage;
}

const jsonLd = generateBlogPostSchema({ title: post.data.title, excerpt: post.data.description, image: resolveImage(post.data.image), publishDate: post.data.pubDate.toISOString(), slug: post.slug });
const breadcrumbSchema = generateBreadcrumbSchema([
 { name: 'Beranda', url: '/' },
 { name: 'Blog', url: '/blog/' },
 { name: post.data.title, url: `/blog/${post.slug}/` }
]);
---

<BaseLayout
 title={`${post.data.title} | Blog ${siteName}`}
 description={post.data.description}
 keywords={`${post.data.title.toLowerCase()}, ${post.data.category.toLowerCase()}`}
 image={resolveImage(post.data.image)}
 type="article"
 jsonLd={[jsonLd, breadcrumbSchema]}
>
 <Header slot="header" />

 <main class="relative overflow-hidden bg-background text-text-main">
 <article class="relative mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[minmax(0,1fr)_300px] lg:px-8 lg:py-20">
 <div class="min-w-0">
 <nav class="mb-10 text-sm text-text-main" aria-label="Breadcrumb">
 <a href="/" class="font-semibold hover:text-text-main">Beranda</a>
 <span class="mx-2">/</span>
 <a href="/blog/" class="font-semibold hover:text-text-main">Blog</a>
 </nav>

 <header class="border-b border-border pb-8">
 <div class="mb-5 flex flex-wrap items-center gap-3 text-sm text-text-secondary">
 <span class={`font-black uppercase tracking-[0.18em] ${accent}`}>{post.data.category}</span>
 <span>•</span>
 <time>{new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
 <span>•</span>
 <span>{post.data.readTime}</span>
 </div>
 <h1 class="display max-w-4xl text-4xl font-black leading-[1.02] tracking-[-0.055em] text-text-main sm:text-6xl lg:text-7xl">{post.data.title}</h1>
 <div class="mt-6 h-[3px] w-24 rounded-full bg-gradient-primary"></div>
 <p class="mt-6 max-w-3xl text-lg leading-8 text-text-secondary sm:text-xl">{post.data.description}</p>
 <div class="mt-7 flex items-center gap-3">
 <div class="flex h-11 w-11 items-center justify-center rounded-full border border-accent/20 bg-surface/60 text-lg font-black text-text-main">{siteName.charAt(0)}</div>
 <div>
 <p class="text-sm font-bold text-text-main">{post.data.author || siteName}</p>
 <p class="text-xs text-text-secondary">Tim editorial {siteName}</p>
 </div>
 </div>
 </header>

 <figure class=" my-10 overflow-hidden rounded-[2rem] border border-accent/20 bg-surface/60 backdrop-blur-sm shadow-lg transition-all duration-500 hover">
 <img
 src={resolveImage(post.data.image)}
 alt={post.data.title}
 class="aspect-[16/9] w-full object-cover"
 loading="eager"
 onerror={`this.onerror=null;this.src='${fallbackImage}';`}
 />
 </figure>

 {toc.length > 0 && (
 <details class="mb-10 rounded-3xl border border-accent/20 bg-surface/60 p-5 backdrop-blur-sm lg:hidden">
 <summary class="cursor-pointer text-sm font-black text-text-main">Daftar Isi</summary>
 <ol class="mt-4 space-y-3 text-sm text-text-secondary">
 {toc.map((heading) => <li class={heading.depth === 3 ? 'ml-4' : ''}><a href={`#${heading.slug}`} class="hover:text-text-main">{heading.text}</a></li>)}
 </ol>
 </details>
 )}

 <div class="article-prose prose prose-lg max-w-none rounded-[2rem] border border-accent/20 bg-surface/60 px-5 py-8 shadow-lg backdrop-blur-sm sm:px-8 lg:px-10 prose-headings:font-black prose-headings:tracking-[-0.035em] prose-headings:text-text-main prose-p:text-[17px] prose-p:leading-8 prose-p:text-text-secondary prose-a:font-bold prose-a:text-accent prose-a:underline prose-a:decoration-accent/30 prose-a:underline-offset-4 prose-a:transition hover:prose-a:decoration-accent prose-strong:font-black prose-strong:text-text-main prose-li:text-[17px] prose-li:leading-8 prose-li:text-text-secondary prose-table:text-sm prose-th:bg-surface-alt prose-th:text-text-main prose-td:text-text-secondary">
 <Content />
 </div>
 </div>

 <aside class="hidden lg:block">
 <div class="sticky top-24 space-y-6">
 {toc.length > 0 && (
 <div class=" rounded-3xl border border-accent/20 bg-surface/60 p-6 backdrop-blur-sm shadow-lg hover">
 <h2 class="mb-4 display text-lg font-black text-text-main">Daftar Isi</h2>
 <ol class="space-y-3 text-sm leading-6 text-text-secondary">
 {toc.map((heading) => <li class={heading.depth === 3 ? 'ml-4' : ''}><a href={`#${heading.slug}`} class="hover:text-text-main">{heading.text}</a></li>)}
 </ol>
 </div>
 )}
 <div class=" rounded-3xl border border-accent/20 bg-surface/60 p-6 backdrop-blur-sm shadow-lg transition-all duration-500 hover:-translate-y-1 hover">
 <h2 class="display text-lg font-black text-text-main">Butuh Konsultasi?</h2>
 <p class="mt-3 text-sm leading-6 text-text-secondary">Diskusikan kebutuhan material, desain, estimasi biaya, dan produksi dengan tim kami.</p>
 <a href={'https://api.whatsapp.com/send?phone=6285165693179&text=Halo%20Raja%20Cutting%20Laser%2C%20saya%20ingin%20konsultasi'} target="_blank" rel="noopener noreferrer" class="mt-5 inline-flex w-full justify-center rounded-full bg-accent px-5 py-3 text-sm font-black text-background transition-all duration-300 hover:bg-accent-orange hover">Konsultasi Sekarang</a>
 </div>
 </div>
 </aside>
 </article>

 {relatedPosts.length > 0 && (
 <section class="relative overflow-hidden border-t border-border py-14">
 <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <div class="mb-8 flex items-end justify-between border-b border-border pb-5">
 <div>
 <p class={`text-sm font-black uppercase tracking-[0.18em] ${accent}`}>Rekomendasi</p>
 <h2 class="mt-2 display-lg text-2xl font-black tracking-[-0.03em] text-text-main">Artikel Terkait</h2>
 </div>
 <a href="/blog/" class="text-sm font-bold text-text-secondary hover:text-text-main">Lihat semua →</a>
 </div>
 <div class="grid gap-7 md:grid-cols-3">
 {relatedPosts.map((relatedPost) => (
 <article class=" group rounded-2xl border border-border bg-surface/60 p-4 backdrop-blur-sm shadow-lg transition-all duration-500 hover:-translate-y-2 hover:border-accent/50 hover">
 <a href={`/blog/${relatedPost.slug}/`} class="block overflow-hidden rounded-3xl border border-border bg-container">
 <img src={resolveImage(relatedPost.data.image)} alt={relatedPost.data.title} class="aspect-[16/10] w-full object-cover transition duration-700 group-hover:scale-[1.04]" loading="lazy" onerror={`this.onerror=null;this.src='${fallbackImage}';`} />
 </a>
 <p class={`mt-5 text-xs font-black uppercase tracking-[0.16em] ${accent}`}>{relatedPost.data.category}</p>
 <h3 class="mt-2 text-lg font-black leading-tight text-text-main"><a href={`/blog/${relatedPost.slug}/`} class="group-hover:text-text-main">{relatedPost.data.title}</a></h3>
 </article>
 ))}
 </div>
 </div>
 </section>
 )}
 </main>

 <Footer slot="footer" />
</BaseLayout>


<style>
 /* No pale text in Raja blog articles: body copy stays near-white. */
 .article-prose,
 .article-prose :global(p),
 .article-prose :global(li),
 .article-prose :global(td),
 .article-prose :global(figcaption),
 .article-prose :global(span) {
 color: #9CA3AF;
 }

 .article-prose :global(p),
 .article-prose :global(li),
 .article-prose :global(td) {
 font-weight: 520;
 letter-spacing: -0.005em;
 }

 .article-prose :global(strong),
 .article-prose :global(b) {
 color: #FFFFFF;
 font-weight: 900;
 }

 .article-prose :global(a) {
 color: #0066FF;
 font-weight: 800;
 }

 .article-prose :global(h2) {
 margin-top: 3rem;
 padding-top: 1.5rem;
 border-top: 1px solid rgba(255, 255, 255, 0.10);
 font-size: clamp(1.75rem, 3vw, 2.5rem);
 line-height: 1.12;
 }

 .article-prose :global(h3) {
 margin-top: 2rem;
 font-size: clamp(1.25rem, 2vw, 1.55rem);
 line-height: 1.25;
 }

 .article-prose :global(p) {
 margin-top: 1.15rem;
 margin-bottom: 1.15rem;
 }

 .article-prose :global(ul),
 .article-prose :global(ol) {
 margin-top: 1.25rem;
 margin-bottom: 1.5rem;
 padding-left: 1.35rem;
 }

 .article-prose :global(li) {
 margin-top: 0.55rem;
 margin-bottom: 0.55rem;
 padding-left: 0.25rem;
 }

 .article-prose :global(li::marker) {
 color: #00FF88;
 font-weight: 900;
 }

 .article-prose :global(blockquote) {
 margin: 2rem 0;
 border-left: 4px solid #00FF88;
 border-radius: 0 1.25rem 1.25rem 0;
 background: #1E1E2A;
 padding: 1.25rem 1.5rem;
 color: #9CA3AF;
 font-weight: 650;
 }

 .article-prose :global(table) {
 display: block;
 width: 100%;
 overflow-x: auto;
 border-collapse: separate;
 border-spacing: 0;
 border: 1px solid #2A2A3A;
 border-radius: 1rem;
 background: #1E1E2A;
 }

 .article-prose :global(th),
 .article-prose :global(td) {
 border-bottom: 1px solid #2A2A3A;
 padding: 0.85rem 1rem;
 vertical-align: top;
 white-space: nowrap;
 }

 .article-prose :global(tbody tr:nth-child(even) td) {
 background: #1E1E2A;
 }

 .article-prose :global(code) {
 border-radius: 0.45rem;
 background: #1E1E2A;
 padding: 0.15rem 0.35rem;
 color: #FFFFFF;
 font-weight: 700;
 }

 @media (max-width: 640px) {
 .article-prose :global(p),
 .article-prose :global(li) {
 font-size: 16px;
 line-height: 1.8;
 }
 }
</style>

