---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { SERVICES, SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';
import { generateMetaTags, generateServiceSchema, generateBreadcrumbSchema, generateFAQSchema } from '../utils/seo.ts';

const service = SERVICES.find(s => s.slug === 'jasa-laser-fiber');
if (!service) { throw new Error(`Service with slug 'jasa-laser-fiber' not found.`); }

const metaTags = generateMetaTags({
  title: "Jasa Laser Fiber Tangerang - Cutting Metal & Stainless Steel Presisi",
  description: "Jasa laser fiber profesional untuk cutting & marking metal, stainless steel, aluminium, tembaga. Presisi 0.05mm. Melayani Jabodetabek. Konsultasi & quote gratis!",
  keywords: service.keywords,
  url: `/${service.slug}/`,
  type: "service",
  image: service.image,
  publishedTime: "2025-01-01T00:00:00Z",
  modifiedTime: "2025-01-01T00:00:00Z",
  author: SITE_CONFIG.author
});

const serviceSchema = generateServiceSchema({ name: service.name, description: service.description, price: "Competitive pricing" });
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Beranda', url: '/' },
  { name: 'Layanan', url: '/#services' },
  { name: service.name, url: `/${service.slug}/` }
]);

const faqItems = [
  { question: "Material logam apa saja yang bisa diproses?", answer: "Stainless steel, carbon steel, aluminium, tembaga, brass, titanium." },
  { question: "Berapa toleransi presisi?", answer: "Hingga ±0.05mm tergantung material dan ketebalan." },
  { question: "Maksimal ketebalan berapa?", answer: "Hingga 20mm untuk stainless/carbon steel, 15mm untuk aluminium." }
];
const faqSchema = generateFAQSchema(faqItems);
---
<BaseLayout metaTags={metaTags} jsonLd={[serviceSchema, breadcrumbSchema, faqSchema]}>
  <Header slot="header" />

  <Hero
    title="Jasa Laser Fiber Tangerang - Cutting Metal Presisi"
    subtitle="Cutting & Marking Metal | Presisi Tinggi | Stainless, Alumunium"
    description="Teknologi laser fiber tercepat dan paling akurat untuk cutting serta marking berbagai jenis material logam. Ideal untuk stainless steel, carbon steel, aluminium, dan tembaga dengan hasil presisi tinggi dan efisiensi biaya maksimal."
    primaryCTA="Konsultasi Laser Fiber"
    secondaryCTA="Lihat Portofolio"
    backgroundImage={service.image}
    whatsappMessage={WHATSAPP_MESSAGES.fiber}
  />

  <!-- Service Overview -->
  <section class="section-padding bg-background cv-auto">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="display-lg text-text-main mb-6">Solusi Cutting & Marking Logam Terdepan</h2>
          <p class="text-xl text-text-secondary mb-8">
            Laser Fiber kami menggunakan teknologi berkekuatan tinggi untuk memberikan hasil cutting dan marking yang sangat presisi pada berbagai material logam. Dengan kecepatan tinggi dan efisiensi biaya, kami menjadi pilihan utama industri manufaktur dan otomotif di Jabodetabek.
          </p>
          
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-surface/60 rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-text-main mb-2">Kecepatan & Efisiensi</h3>
                <p class="text-text-secondary">Proses cutting super cepat yang meningkatkan produktivitas dan efisiensi biaya.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-surface/60 rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-text-main mb-2">Presisi Mikro</h3>
                <p class="text-text-secondary">Akurasi hingga 0.05mm untuk komponen dengan toleransi ketat dan detail rumit.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-surface/60 rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-text-main mb-2">Tanpa Kontak Fisik</h3>
                <p class="text-text-secondary">Meminimalkan deformasi material karena tidak ada tekanan fisik saat pemotongan.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="relative">
          <OptimizedImage 
            src={service.image} 
            alt={service.name}
            className="rounded-xl shadow-xl w-full"
            loading="lazy"
            width={600}
            height={400}
          />
          <div class="absolute -bottom-6 -right-6 bg-surface/60 rounded-lg shadow-lg p-6 text-right">
            <div class="text-3xl font-bold text-accent mb-1">20mm</div>
            <div class="text-text-secondary text-sm">Maksimal Tebal</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="section-padding bg-surface/60 cv-auto">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="display-lg text-text-main mb-4">Proses Pengerjaan Laser Fiber</h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          Alur kerja profesional untuk memastikan hasil cutting metal yang presisi dan tepat waktu
        </p>
      </div>
      
      <div class="grid md:grid-cols-4 gap-8">
        <div class="bg-background rounded-xl p-6 text-center shadow-md relative border border-accent/20">
          <div class="w-12 h-12 bg-accent text-background rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">1</div>
          <h3 class="text-lg font-bold text-text-main mb-2">Desain & File</h3>
          <p class="text-text-secondary text-sm">Verifikasi file CAD (.dxf, .dwg) dan optimasi nesting.</p>
        </div>
        <div class="bg-background rounded-xl p-6 text-center shadow-md relative border border-accent/20">
          <div class="w-12 h-12 bg-accent text-background rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">2</div>
          <h3 class="text-lg font-bold text-text-main mb-2">Setup Mesin</h3>
          <p class="text-text-secondary text-sm">Pengaturan parameter laser sesuai jenis dan ketebalan logam.</p>
        </div>
        <div class="bg-background rounded-xl p-6 text-center shadow-md relative border border-accent/20">
          <div class="w-12 h-12 bg-accent text-background rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">3</div>
          <h3 class="text-lg font-bold text-text-main mb-2">Eksekusi Laser</h3>
          <p class="text-text-secondary text-sm">Proses pemotongan otomatis dengan kecepatan tinggi.</p>
        </div>
        <div class="bg-background rounded-xl p-6 text-center shadow-md relative border border-accent/20">
          <div class="w-12 h-12 bg-accent text-background rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">4</div>
          <h3 class="text-lg font-bold text-text-main mb-2">QC & Delivery</h3>
          <p class="text-text-secondary text-sm">Pemeriksaan dimensi dan finishing sebelum pengiriman.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Material Capabilities -->
  <section class="section-padding bg-background cv-auto">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="display-lg text-text-main mb-4">Material Logam yang Diproses</h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          Kemampuan mesin kami mencakup berbagai jenis logam industri
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-surface/60 p-6 rounded-lg border border-accent/20">
          <h3 class="text-xl font-bold text-text-main mb-2">Stainless Steel</h3>
          <p class="text-text-secondary">SS304, SS316, SS201, SS430. Hingga ketebalan 20mm.</p>
        </div>
        <div class="bg-surface/60 p-6 rounded-lg border border-accent/20">
          <h3 class="text-xl font-bold text-text-main mb-2">Carbon Steel / Mild Steel</h3>
          <p class="text-text-secondary">Plat besi hitam, SPHC, SPCC. Hingga ketebalan 25mm.</p>
        </div>
        <div class="bg-surface/60 p-6 rounded-lg border border-accent/20">
          <h3 class="text-xl font-bold text-text-main mb-2">Aluminium</h3>
          <p class="text-text-secondary">Series 1xxx, 3xxx, 5xxx. Hingga ketebalan 15mm.</p>
        </div>
        <div class="bg-surface/60 p-6 rounded-lg border border-accent/20">
          <h3 class="text-xl font-bold text-text-main mb-2">Tembaga / Copper</h3>
          <p class="text-text-secondary">Plat tembaga murni. Hingga ketebalan 8mm.</p>
        </div>
        <div class="bg-surface/60 p-6 rounded-lg border border-accent/20">
          <h3 class="text-xl font-bold text-text-main mb-2">Kuningan / Brass</h3>
          <p class="text-text-secondary">Plat kuningan untuk dekoratif. Hingga ketebalan 8mm.</p>
        </div>
        <div class="bg-surface/60 p-6 rounded-lg border border-accent/20">
          <h3 class="text-xl font-bold text-text-main mb-2">Galvanized Steel</h3>
          <p class="text-text-secondary">Plat galvanis tahan karat. Hingga ketebalan 6mm.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Features -->
  <section class="section-padding bg-surface/60 cv-auto">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="display-lg text-text-main mb-4">Keunggulan Layanan Kami</h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          Mengapa memilih layanan Laser Fiber dari Raja Cutting Laser
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {service.features.map((feature, index) => (
          <div class="bg-background p-6 border border-accent/20 transition-all duration-300">
            <div class="w-10 h-10 bg-accent/20 text-accent rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-text-main mb-1">{feature}</h3>
              <p class="text-text-secondary text-sm">Standar kualitas tinggi untuk hasil terbaik.</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Applications -->
  <section class="section-padding bg-background cv-auto">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="display-lg text-text-main mb-4">Aplikasi Industri</h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          Solusi laser cutting untuk berbagai sektor industri
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {service.applications.map((application, index) => (
          <div class="bg-gradient-to-br from-container to-background rounded-xl p-6 hover:shadow-lg transition-all duration-300 border border-accent/10">
            <div class="text-4xl font-bold text-accent/60 mb-2">0{index + 1}</div>
            <h3 class="text-lg font-bold text-text-main mb-2">{application}</h3>
            <p class="text-text-secondary text-sm">Penerapan teknologi laser fiber untuk kebutuhan {application.toLowerCase()}.</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA 
    title="Butuh Jasa Laser Cutting Metal?"
    description="Konsultasikan kebutuhan cutting metal Anda. Dapatkan penawaran harga terbaik dan hasil presisi tinggi."
    variant="gradient"
    size="lg"
  />

  <Footer slot="footer" />
</BaseLayout>