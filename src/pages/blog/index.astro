---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts
 .filter(post => !post.data.draft)
 .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const siteName = 'Raja Cutting Laser';
const accent = 'text-accent';
const fallbackImage = '/images/metal.webp';
function resolveImage(image: string | undefined): string {
 if (!image) return fallbackImage;
 if (image.startsWith('http://') || image.startsWith('https://')) return image;
 const normalized = image.startsWith('/') ? image : `/${image}`;
 return existsSync(join(process.cwd(), 'public', normalized.slice(1))) ? normalized : fallbackImage;
}

const baseUrl = Astro.site ? Astro.site.toString() : 'https://rajacuttinglaser.com/';
const blogUrl = `${baseUrl}blog/`;
const featuredPost = sortedPosts[0];
const otherPosts = sortedPosts.slice(1);

const jsonLd = {
 "@context": "https://schema.org",
 "@type": "Blog",
 "name": `Blog ${siteName}`,
 "description": 'Panduan teknis, estimasi, dan insight manufaktur untuk laser fiber, laser CO2, CNC router, serta fabrikasi logam presisi.',
 "url": blogUrl,
 "publisher": { "@type": "Organization", "name": siteName }
};
---

<BaseLayout
 title={`Blog - ${siteName}`}
 description={'Panduan teknis, estimasi, dan insight manufaktur untuk laser fiber, laser CO2, CNC router, serta fabrikasi logam presisi.'}
 keywords={'blog raja cutting laser, laser fiber, cnc router, fabrikasi logam'}
 jsonLd={[jsonLd]}
>
 <Header slot="header" />

 <div class="bg-background text-text-main">
 <section class="relative overflow-hidden border-b border-border bg-background">
 <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
 <div class="max-w-3xl">
 <a href="/" class="mb-10 inline-flex items-center gap-2 text-sm font-semibold text-text-secondary transition hover:text-text-main">← Kembali ke Beranda</a>
 <p class={`mb-4 text-xs font-black uppercase tracking-[0.24em] ${accent}`}>Insight & Panduan</p>
 <h1 class="display max-w-4xl text-5xl font-black leading-[0.98] tracking-[-0.055em] text-text-main sm:text-6xl lg:text-7xl">
 Blog {siteName}
 </h1>
 <div class="mt-6 h-[3px] w-24 rounded-full bg-gradient-primary"></div>
 <p class="mt-7 max-w-2xl text-lg leading-8 text-text-secondary sm:text-xl">
 {'Panduan teknis, estimasi, dan insight manufaktur untuk laser fiber, laser CO2, CNC router, serta fabrikasi logam presisi.'}
 </p>
 </div>
 </div>
 </section>

 {featuredPost && (
 <section class="relative overflow-hidden border-b border-border">
 <div class="relative mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
 <a href={`/blog/${featuredPost.slug}/`} class="group grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
 <div class=" overflow-hidden rounded-[2rem] border border-border bg-surface/60 backdrop-blur-sm transition-all duration-500 group-hover:border-accent/50 group-hover">
 <img
 src={resolveImage(featuredPost.data.image)}
 alt={featuredPost.data.imageAlt}
 class="aspect-[16/10] h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]"
 loading="eager"
 onerror={`this.onerror=null;this.src='${fallbackImage}';`}
 />
 </div>
 <div class="bg-container/80 backdrop-blur-sm rounded-2xl border border-border p-7 shadow-lg transition-all duration-500 group-hover">
 <div class="mb-5 flex flex-wrap items-center gap-3 text-sm text-text-secondary">
 <span class={`font-black uppercase tracking-[0.18em] ${accent}`}>{featuredPost.data.category}</span>
 <span>•</span>
 <time>{new Date(featuredPost.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
 <span>•</span>
 <span>{featuredPost.data.readTime}</span>
 </div>
 <h2 class="display-lg text-3xl font-black leading-tight tracking-[-0.035em] text-text-main sm:text-5xl">{featuredPost.data.title}</h2>
 <p class="mt-5 text-lg leading-8 text-text-secondary">{featuredPost.data.description}</p>
 <span class="mt-8 inline-flex items-center gap-2 rounded-full border border-accent/20 bg-surface/60 px-5 py-3 text-sm font-bold text-text-main transition group-hover:border-accent/50">Baca artikel utama →</span>
 </div>
 </a>
 </div>
 </section>
 )}

 <section class="relative overflow-hidden py-14 lg:py-20">
 <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
 <div class="mb-8 flex items-end justify-between gap-6 border-b border-border pb-5">
 <div>
 <p class={`text-sm font-black uppercase tracking-[0.18em] ${accent}`}>Semua artikel</p>
 <h2 class="mt-2 display-lg text-2xl font-black tracking-[-0.03em] text-text-main">Terbaru dari blog</h2>
 </div>
 <p class="hidden text-sm text-text-secondary sm:block">{sortedPosts.length} artikel tersedia</p>
 </div>
 <div class="grid gap-x-7 gap-y-10 md:grid-cols-2 lg:grid-cols-3">
 {otherPosts.map((post) => (
 <article class=" group rounded-2xl border border-border bg-surface/60 p-4 backdrop-blur-sm shadow-lg transition-all duration-500 hover:-translate-y-2 hover:border-accent/50 hover">
 <a href={`/blog/${post.slug}/`} class="block overflow-hidden rounded-3xl border border-border bg-container">
 <img
 src={resolveImage(post.data.image)}
 alt={post.data.imageAlt}
 class="aspect-[16/10] w-full object-cover transition duration-700 group-hover:scale-[1.04]"
 loading="lazy"
 onerror={`this.onerror=null;this.src='${fallbackImage}';`}
 />
 </a>
 <div class="pt-5">
 <div class="mb-3 flex flex-wrap items-center gap-2 text-xs text-text-secondary">
 <span class={`font-black uppercase tracking-[0.16em] ${accent}`}>{post.data.category}</span>
 <span>•</span>
 <time>{new Date(post.data.pubDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}</time>
 </div>
 <h3 class="text-xl font-black leading-tight tracking-[-0.025em] text-text-main">
 <a href={`/blog/${post.slug}/`} class="transition group-hover:text-text-main">{post.data.title}</a>
 </h3>
 <p class="mt-3 line-clamp-3 text-[15px] leading-7 text-text-secondary">{post.data.description}</p>
 <a href={`/blog/${post.slug}/`} class="mt-5 inline-flex text-sm font-bold text-text-main underline decoration-border underline-offset-4 transition hover:decoration-text-main">Baca selengkapnya</a>
 </div>
 </article>
 ))}
 </div>
 </div>
 </section>

 </div>

 <Footer slot="footer" />
</BaseLayout>
