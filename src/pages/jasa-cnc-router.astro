---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { SERVICES, SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';
import { generateMetaTags, generateServiceSchema, generateBreadcrumbSchema } from '../utils/seo.ts';

const service = SERVICES.find(s => s.slug === 'jasa-cnc-router');
if (!service) { throw new Error('CNC Router service not found in SERVICES array'); }

const metaTags = generateMetaTags({
  title: "Jasa CNC Router Tangerang Selatan - Presisi 0.1mm | Raja Cutting Laser",
  description: "Jasa CNC Router profesional untuk cutting & engraving kayu, MDF, plastik. Presisi hingga 0.1mm, area kerja 2x3 meter. Melayani Jabodetabek. Konsultasi gratis!",
  keywords: service.keywords,
  url: `/jasa-cnc-router/`,
  type: "service",
  image: service.image,
  publishedTime: "2025-01-01T00:00:00Z",
  modifiedTime: "2025-01-01T00:00:00Z",
  author: SITE_CONFIG.author
});

const serviceSchema = generateServiceSchema({ name: service.name, description: service.description, price: "Competitive pricing" });
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Beranda', url: '/' },
  { name: 'Layanan', url: '/#services' },
  { name: service.name, url: '/jasa-cnc-router/' }
]);
---

<BaseLayout 
  title={metaTags.title}
  description={metaTags.description}
  keywords={metaTags.keywords}
  url={metaTags.canonical}
  jsonLd={[serviceSchema, breadcrumbSchema]}
>
  <Header slot="header" />
  
  <!-- Hero Section -->
  <Hero
    title="Jasa CNC Router Profesional di Tangerang - Cutting Kayu & MDF Presisi Tinggi"
    subtitle="Presisi 0.1mm | Material Kayu & MDF | Ukuran hingga 2x3 Meter"
    description="Teknologi CNC Router terdepan untuk cutting dan engraving material kayu, MDF, dan plastik dengan hasil sempurna. Cocok untuk furniture, signage, prototype, dan dekorasi."
    primaryCTA="Konsultasi CNC Router"
    secondaryCTA="Lihat Portofolio"
    backgroundImage={service.image}
    whatsappMessage={WHATSAPP_MESSAGES.cnc}
  />

  <!-- Service Overview -->
  <section class="section-padding bg-background cv-auto">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="heading-lg text-text-main mb-6">Solusi Cutting & Engraving Presisi Tinggi</h2>
          <p class="text-xl text-text-secondary mb-8">
            CNC Router kami mampu memotong dan mengukir material kayu dan MDF dengan presisi hingga 0.1mm, menjadikannya pilihan utama untuk project berkualitas tinggi di Jabodetabek.
          </p>
          
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-container rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-text-main mb-2">Presisi Tinggi 0.1mm</h3>
                <p class="text-text-secondary">Toleransi cutting yang sangat ketat untuk hasil akurat dan konsisten.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-container rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 00-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-text-main mb-2">Ukuran Maksimal 2x3 Meter</h3>
                <p class="text-text-secondary">Area kerja luas untuk memenuhi kebutuhan project besar Anda.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-container rounded-lg flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-bold text-text-main mb-2">Multi-Material</h3>
                <p class="text-text-secondary">Mampu memproses berbagai jenis kayu, MDF, dan plastik.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="relative">
          <OptimizedImage 
            src={service.image} 
            alt={service.name}
            className="rounded-xl shadow-xl w-full"
            loading="lazy"
            width={600}
            height={400}
          />
          <div class="absolute -bottom-6 -left-6 bg-container rounded-lg shadow-lg p-6">
            <div class="text-3xl font-bold text-button mb-1">0.1mm</div>
            <div class="text-text-secondary text-sm">Presisi Tinggi</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="section-padding bg-container cv-auto">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="heading-lg text-text-main mb-4">Proses Pengerjaan CNC Router</h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          Kami memastikan setiap project Anda dikerjakan dengan standar kualitas tinggi dan presisi maksimal
        </p>
      </div>
      
      <div class="relative">
        <div class="hidden lg:block absolute top-16 left-1/2 transform -translate-x-1/2 h-full w-0.5 bg-primary" aria-hidden="true"></div>
        
        <div class="grid md:grid-cols-2 gap-8 relative">
          <div class="bg-background rounded-xl shadow-lg p-8 relative">
            <div class="absolute -top-4 -left-4 w-8 h-8 bg-button rounded-full flex items-center justify-center text-white font-bold" aria-hidden="true">1</div>
            <div class="hidden md:block absolute top-8 left-full w-full h-0.5 bg-primary transform -translate-y-1/2" aria-hidden="true"></div>
            <h3 class="text-xl font-bold text-text-main mb-4">Setup & Programming</h3>
            <p class="text-text-secondary leading-relaxed">
              Persiapan mesin, programming toolpath, dan setting parameter cutting sesuai dengan material dan design.
            </p>
          </div>
          
          <div class="bg-background rounded-xl shadow-lg p-8 relative md:mt-16">
            <div class="absolute -top-4 -left-4 w-8 h-8 bg-button rounded-full flex items-center justify-center text-white font-bold" aria-hidden="true">2</div>
            <div class="hidden md:block absolute top-8 left-0 w-full h-0.5 bg-primary transform -translate-y-1/2 -translate-x-full" aria-hidden="true"></div>
            <h3 class="text-xl font-bold text-text-main mb-4">Cutting & Engraving</h3>
            <p class="text-text-secondary leading-relaxed">
              Proses cutting dan engraving dilakukan dengan presisi tinggi menggunakan teknologi CNC Router terkini.
            </p>
          </div>
          
          <div class="bg-background rounded-xl shadow-lg p-8 relative md:mt-16">
            <div class="absolute -top-4 -left-4 w-8 h-8 bg-button rounded-full flex items-center justify-center text-white font-bold" aria-hidden="true">3</div>
            <div class="hidden md:block absolute top-8 left-full w-full h-0.5 bg-primary transform -translate-y-1/2" aria-hidden="true"></div>
            <h3 class="text-xl font-bold text-text-main mb-4">Finishing & Quality Check</h3>
            <p class="text-text-secondary leading-relaxed">
              Pemolesan, pembersihan, dan pengecekan kualitas untuk memastikan hasil akhir memenuhi standar tinggi kami.
            </p>
          </div>
          
          <div class="bg-background rounded-xl shadow-lg p-8 relative">
            <div class="absolute -top-4 -left-4 w-8 h-8 bg-button rounded-full flex items-center justify-center text-white font-bold" aria-hidden="true">4</div>
            <div class="hidden md:block absolute top-8 left-0 w-full h-0.5 bg-primary transform -translate-y-1/2 -translate-x-full" aria-hidden="true"></div>
            <h3 class="text-xl font-bold text-text-main mb-4">Delivery & Installation</h3>
            <p class="text-text-secondary leading-relaxed">
              Pengiriman tepat waktu dan instalasi (jika diperlukan) oleh tim ahli kami di area Jabodetabek.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Material Capabilities -->
  <section class="section-padding bg-background cv-auto">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="heading-lg text-text-main mb-4">Material yang Dapat Diproses</h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          CNC Router kami dirancang untuk memberikan hasil terbaik pada berbagai jenis material
        </p>
      </div>
      
      <div class="bg-container rounded-xl shadow-lg p-8">
        <h3 class="text-2xl font-bold text-text-main mb-6">Material yang Dapat Diproses</h3>
        <div class="space-y-6">
          <div class="bg-background rounded-lg p-4">
            <h4 class="font-semibold text-text-main mb-3">Kayu & Turunannya</h4>
            <ul class="space-y-2 text-text-secondary">
              <li class="flex items-center space-x-2"><span class="w-2 h-2 bg-button rounded-full"></span><span>Kayu solid (Pine, Oak, Mahogany)</span></li>
              <li class="flex items-center space-x-2"><span class="w-2 h-2 bg-button rounded-full"></span><span>MDF (Medium Density Fiberboard)</span></li>
              <li class="flex items-center space-x-2"><span class="w-2 h-2 bg-button rounded-full"></span><span>Plywood/Multiplex</span></li>
              <li class="flex items-center space-x-2"><span class="w-2 h-2 bg-button rounded-full"></span><span>Blockboard</span></li>
            </ul>
          </div>
          
          <div class="bg-background rounded-lg p-4">
            <h4 class="font-semibold text-text-main mb-3">Plastik & Komposit</h4>
            <ul class="space-y-2 text-text-secondary">
              <li class="flex items-center space-x-2"><span class="w-2 h-2 bg-button rounded-full"></span><span>Acrylic/Plexiglass</span></li>
              <li class="flex items-center space-x-2"><span class="w-2 h-2 bg-button rounded-full"></span><span>HDPE (High-Density Polyethylene)</span></li>
              <li class="flex items-center space-x-2"><span class="w-2 h-2 bg-button rounded-full"></span><span>PP (Polypropylene)</span></li>
              <li class="flex items-center space-x-2"><span class="w-2 h-2 bg-button rounded-full"></span><span>PVC Foam Board</span></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Features -->
  <section class="section-padding bg-container cv-auto">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="heading-lg text-text-main mb-4">Keunggulan Layanan CNC Router Kami</h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          Mengapa memilih layanan CNC Router dari Raja Cutting Laser untuk project Anda
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-background rounded-xl shadow-lg p-6 text-center hover:shadow-xl transition-shadow duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.features[0]}</h3>
            <p class="text-text-secondary text-sm">Hasil pemotongan akurat dengan toleransi sangat ketat untuk detail sempurna.</p>
        </div>
        <div class="bg-background rounded-xl shadow-lg p-6 text-center hover:shadow-xl transition-shadow duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.features[1]}</h3>
            <p class="text-text-secondary text-sm">Kapasitas mesin besar memungkinkan pengerjaan material ukuran penuh tanpa sambungan.</p>
        </div>
        <div class="bg-background rounded-xl shadow-lg p-6 text-center hover:shadow-xl transition-shadow duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.features[2]}</h3>
            <p class="text-text-secondary text-sm">Kemampuan memproses berbagai material seperti kayu, MDF, ACP, PVC, dan akrilik.</p>
        </div>
        <div class="bg-background rounded-xl shadow-lg p-6 text-center hover:shadow-xl transition-shadow duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4">
               <svg class="w-8 h-8 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.features[3]}</h3>
            <p class="text-text-secondary text-sm">Mampu membuat ukiran 3D dan grafir detail untuk kebutuhan artistik.</p>
        </div>
        <div class="bg-background rounded-xl shadow-lg p-6 text-center hover:shadow-xl transition-shadow duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4">
               <svg class="w-8 h-8 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.features[4]}</h3>
            <p class="text-text-secondary text-sm">Hasil potongan bersih dan rapi, meminimalkan kebutuhan proses finishing lanjutan.</p>
        </div>
        <div class="bg-background rounded-xl shadow-lg p-6 text-center hover:shadow-xl transition-shadow duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4">
               <svg class="w-8 h-8 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.features[5]}</h3>
            <p class="text-text-secondary text-sm">Didukung mesin berkecepatan tinggi untuk efisiensi produksi massal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Applications -->
  <section class="section-padding bg-background cv-auto">
    <div class="container-custom">
      <div class="text-center mb-16">
        <h2 class="heading-lg text-text-main mb-4">Aplikasi CNC Router</h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          Berbagai aplikasi industri yang dapat ditangani dengan teknologi CNC Router kami
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="bg-gradient-to-br from-container to-background rounded-xl p-6 text-center hover:shadow-lg transition-all duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4 shadow-md"><span class="text-2xl font-bold text-button">1</span></div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.applications[0]}</h3>
            <p class="text-text-secondary text-sm">Pembuatan komponen furniture presisi, panel dekoratif, dan ornamen ukiran kayu.</p>
          </div>
          <div class="bg-gradient-to-br from-container to-background rounded-xl p-6 text-center hover:shadow-lg transition-all duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4 shadow-md"><span class="text-2xl font-bold text-button">2</span></div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.applications[1]}</h3>
            <p class="text-text-secondary text-sm">Huruf timbul, neon box, dan display produk dari bahan akrilik atau PVC.</p>
          </div>
          <div class="bg-gradient-to-br from-container to-background rounded-xl p-6 text-center hover:shadow-lg transition-all duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4 shadow-md"><span class="text-2xl font-bold text-button">3</span></div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.applications[2]}</h3>
            <p class="text-text-secondary text-sm">Pembuatan model skala dan purwarupa produk dengan akurasi dimensi tinggi.</p>
          </div>
          <div class="bg-gradient-to-br from-container to-background rounded-xl p-6 text-center hover:shadow-lg transition-all duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4 shadow-md"><span class="text-2xl font-bold text-button">4</span></div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.applications[3]}</h3>
            <p class="text-text-secondary text-sm">Partisi ruangan (room divider), wall panel 3D, dan elemen dekoratif interior.</p>
          </div>
          <div class="bg-gradient-to-br from-container to-background rounded-xl p-6 text-center hover:shadow-lg transition-all duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4 shadow-md"><span class="text-2xl font-bold text-button">5</span></div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.applications[4]}</h3>
            <p class="text-text-secondary text-sm">Suku cadang mesin, jig, dan fixture dari material engineering plastic.</p>
          </div>
          <div class="bg-gradient-to-br from-container to-background rounded-xl p-6 text-center hover:shadow-lg transition-all duration-300">
            <div class="w-16 h-16 bg-container rounded-full flex items-center justify-center mx-auto mb-4 shadow-md"><span class="text-2xl font-bold text-button">6</span></div>
            <h3 class="text-lg font-bold text-text-main mb-2">{service.applications[5]}</h3>
            <p class="text-text-secondary text-sm">Produk kerajinan tangan, souvenir, dan merchandise kayu dengan desain custom.</p>
          </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA 
    title="Butuh CNC Router Profesional?"
    description="Konsultasikan kebutuhan CNC Router Anda dengan tim ahli kami. Dapatkan quote terbaik dan solusi tepat untuk project Anda."
    variant="gradient"
    size="lg"
  />

  <Footer slot="footer" />
</BaseLayout>
