---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const siteName = 'Raja Cutting Laser';
---

<BaseLayout
  title={`Halaman Tidak Ditemukan | ${siteName}`}
  description="Halaman yang Anda cari tidak ditemukan."
  keywords="404, halaman tidak ditemukan"
  jsonLd={[]}
>
  <Header slot="header" />

  <main class="bg-background text-text-main flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="text-5xl font-black tracking-tight text-text-main sm:text-6xl">404</h1>
    <p class="mt-4 max-w-md text-lg text-text-secondary">
      Maaf, halaman yang Anda cari tidak ada.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex rounded-full bg-accent px-6 py-3 text-sm font-black text-black transition hover:bg-accent/80"
    >
      Kembali ke Beranda
    </a>
  </main>

  <Footer slot="footer" />
</BaseLayout>
