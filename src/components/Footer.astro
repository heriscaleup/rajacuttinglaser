---
import { PRODUCT_CATEGORIES } from '../data/productCatalog.js';
import { SERVICES, SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsapp}?text=${encodeURIComponent(WHATSAPP_MESSAGES.productDefault)}`;
---

<footer class="relative overflow-hidden border-t border-white/10 bg-[#080a09] text-text-secondary">
  <div class="pointer-events-none absolute inset-0 metal-grain" aria-hidden="true"></div>
  <div class="container-custom relative py-16 md:py-24">
    <div class="grid gap-14 border-b border-white/10 pb-16 lg:grid-cols-[1.4fr_0.6fr_0.7fr_0.8fr] lg:gap-10 lg:pb-24">
      <div class="max-w-xl">
        <a href="/" class="inline-flex items-center gap-3" aria-label="Raja Cutting Laser — Beranda">
          <img src="/images/logo.webp" alt="Logo Raja Cutting Laser" class="h-11 w-11 object-contain transition-transform duration-300 hover:scale-105" />
          <span class="text-base font-extrabold uppercase tracking-[0.14em] text-text-main">Raja Cutting Laser</span>
        </a>
        <p class="mt-7 max-w-md text-base leading-relaxed">Menerjemahkan ide arsitektur, interior, dan identitas brand menjadi produk custom yang siap dipotong, difabrikasi, dan dipasang.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={SITE_CONFIG.socialMedia.instagram} target="_blank" rel="noopener noreferrer" class="tag transition-colors hover:border-accent hover:text-text-main">Instagram</a>
          <a href={SITE_CONFIG.socialMedia.youtube} target="_blank" rel="noopener noreferrer" class="tag transition-colors hover:border-accent hover:text-text-main">YouTube</a>
          <a href={SITE_CONFIG.socialMedia.facebook} target="_blank" rel="noopener noreferrer" class="tag transition-colors hover:border-accent hover:text-text-main">Facebook</a>
        </div>
      </div>

      <div>
        <p class="mb-6 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-text-main">Produk</p>
        <ul class="space-y-3.5">
          {PRODUCT_CATEGORIES.slice(0, 6).map((product) => (
            <li><a href={product.href} class="text-sm transition-colors hover:text-accent">{product.shortName}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="mb-6 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-text-main">Teknologi</p>
        <ul class="space-y-3.5">
          {SERVICES.map((service) => (
            <li><a href={`/${service.slug}/`} class="text-sm transition-colors hover:text-accent">{service.name}</a></li>
          ))}
          <li><a href="/portfolio/" class="text-sm transition-colors hover:text-accent">Portfolio</a></li>
          <li><a href="/blog/" class="text-sm transition-colors hover:text-accent">Insight</a></li>
        </ul>
      </div>

      <div>
        <p class="mb-6 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-text-main">Studio & workshop</p>
        <address class="not-italic">
          <p class="text-sm leading-relaxed">{SITE_CONFIG.address}</p>
          <a href={`tel:${SITE_CONFIG.phone}`} class="mt-5 block text-sm font-semibold text-text-main transition-colors hover:text-accent">{SITE_CONFIG.phone}</a>
          <a href={`mailto:${SITE_CONFIG.email}`} class="mt-2 block break-all text-sm transition-colors hover:text-accent">{SITE_CONFIG.email}</a>
          <p class="mt-5 font-mono text-[0.6rem] uppercase tracking-[0.12em]">{SITE_CONFIG.businessHours}</p>
        </address>
      </div>
    </div>

    <div class="flex flex-col gap-6 pt-8 text-xs md:flex-row md:items-center md:justify-between">
      <p>© 2026 Raja Cutting Laser. Tangerang Selatan, Indonesia.</p>
      <div class="flex flex-wrap items-center gap-5 font-mono text-[0.58rem] uppercase tracking-[0.12em]">
        <span>Fiber</span><span>CO₂</span><span>CNC</span><span>Galvo</span>
        <button type="button" class="ml-2 inline-flex items-center gap-2 text-text-main transition-colors hover:text-accent" data-back-to-top>
          Kembali ke atas
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m6 15 6-6 6 6" /></svg>
        </button>
      </div>
    </div>
  </div>

  <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" aria-label="Konsultasi via WhatsApp" class="fixed bottom-5 right-5 z-30 inline-flex h-14 items-center gap-3 rounded-full bg-accent px-5 text-sm font-bold text-text-main shadow-[0_16px_44px_rgba(0,0,0,0.35)] transition duration-300 hover:-translate-y-1 hover:bg-accent-orange sm:bottom-8 sm:right-8">
    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488" /></svg>
    <span class="hidden sm:inline">Diskusikan proyek</span>
  </a>

  <script>
    document.querySelector('[data-back-to-top]')?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  </script>
</footer>
