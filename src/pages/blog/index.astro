---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const siteName = 'Raja Cutting Laser';
const accent = 'text-blue-700';
const fallbackImage = '/images/metal.webp';
function resolveImage(image) {
  if (!image) return fallbackImage;
  if (image.startsWith('http://') || image.startsWith('https://')) return image;
  const normalized = image.startsWith('/') ? image : `/${image}`;
  return existsSync(join(process.cwd(), 'public', normalized.slice(1))) ? normalized : fallbackImage;
}

const baseUrl = Astro.site ? Astro.site.toString() : 'https://rajacuttinglaser.com/';
const blogUrl = `${baseUrl}blog/`;
const featuredPost = sortedPosts[0];
const otherPosts = sortedPosts.slice(1);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": `Blog ${siteName}`,
  "description": 'Panduan teknis, estimasi, dan insight manufaktur untuk laser fiber, laser CO2, CNC router, serta fabrikasi logam presisi.',
  "url": blogUrl,
  "publisher": { "@type": "Organization", "name": siteName }
};
---

<BaseLayout
  title={`Blog - ${siteName}`}
  description={'Panduan teknis, estimasi, dan insight manufaktur untuk laser fiber, laser CO2, CNC router, serta fabrikasi logam presisi.'}
  keywords={'blog raja cutting laser, laser fiber, cnc router, fabrikasi logam'}
  jsonLd={[jsonLd]}
>
  <Header slot="header" />

  <main class="bg-[#fbfaf7] text-[#171717]">
    <section class="border-b border-black/10 bg-[#fbfaf7]">
      <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
        <div class="max-w-3xl">
          <a href="/" class="mb-10 inline-flex items-center gap-2 text-sm font-semibold text-neutral-950 transition hover:text-neutral-950">← Kembali ke Beranda</a>
          <p class={`mb-4 text-xs font-black uppercase tracking-[0.24em] ${accent}`}>Insight & Panduan</p>
          <h1 class="max-w-4xl text-5xl font-black leading-[0.98] tracking-[-0.055em] text-neutral-950 sm:text-6xl lg:text-7xl">
            Blog {siteName}
          </h1>
          <p class="mt-7 max-w-2xl text-lg leading-8 text-neutral-950 sm:text-xl">
            {'Panduan teknis, estimasi, dan insight manufaktur untuk laser fiber, laser CO2, CNC router, serta fabrikasi logam presisi.'}
          </p>
        </div>
      </div>
    </section>

    {featuredPost && (
      <section class="border-b border-black/10">
        <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
          <a href={`/blog/${featuredPost.slug}/`} class="group grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
            <div class="overflow-hidden rounded-[2rem] border border-black/10 bg-neutral-100">
              <img
                src={resolveImage(featuredPost.data.image)}
                alt={featuredPost.data.title}
                class="aspect-[16/10] h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]"
                loading="eager"
                onerror={`this.onerror=null;this.src='${fallbackImage}';`}
              />
            </div>
            <div>
              <div class="mb-5 flex flex-wrap items-center gap-3 text-sm text-neutral-900">
                <span class={`font-black uppercase tracking-[0.18em] ${accent}`}>{featuredPost.data.category}</span>
                <span>•</span>
                <time>{new Date(featuredPost.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                <span>•</span>
                <span>{featuredPost.data.readTime}</span>
              </div>
              <h2 class="text-3xl font-black leading-tight tracking-[-0.035em] text-neutral-950 sm:text-5xl">{featuredPost.data.title}</h2>
              <p class="mt-5 text-lg leading-8 text-neutral-950">{featuredPost.data.description}</p>
              <span class="mt-8 inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-5 py-3 text-sm font-bold text-neutral-900 transition group-hover:border-neutral-950">Baca artikel utama →</span>
            </div>
          </a>
        </div>
      </section>
    )}

    <section class="py-14 lg:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-8 flex items-end justify-between gap-6 border-b border-black/10 pb-5">
          <div>
            <p class="text-sm font-semibold text-neutral-900">Semua artikel</p>
            <h2 class="text-2xl font-black tracking-[-0.03em] text-neutral-950">Terbaru dari blog</h2>
          </div>
          <p class="hidden text-sm text-neutral-900 sm:block">{sortedPosts.length} artikel tersedia</p>
        </div>
        <div class="grid gap-x-7 gap-y-10 md:grid-cols-2 lg:grid-cols-3">
          {otherPosts.map((post) => (
            <article class="group border-b border-black/10 pb-8">
              <a href={`/blog/${post.slug}/`} class="block overflow-hidden rounded-3xl border border-black/10 bg-neutral-100">
                <img
                  src={resolveImage(post.data.image)}
                  alt={post.data.title}
                  class="aspect-[16/10] w-full object-cover transition duration-700 group-hover:scale-[1.04]"
                  loading="lazy"
                  onerror={`this.onerror=null;this.src='${fallbackImage}';`}
                />
              </a>
              <div class="pt-5">
                <div class="mb-3 flex flex-wrap items-center gap-2 text-xs text-neutral-900">
                  <span class={`font-black uppercase tracking-[0.16em] ${accent}`}>{post.data.category}</span>
                  <span>•</span>
                  <time>{new Date(post.data.pubDate).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}</time>
                </div>
                <h3 class="text-xl font-black leading-tight tracking-[-0.025em] text-neutral-950">
                  <a href={`/blog/${post.slug}/`} class="transition group-hover:text-neutral-950">{post.data.title}</a>
                </h3>
                <p class="mt-3 line-clamp-3 text-[15px] leading-7 text-neutral-950">{post.data.description}</p>
                <a href={`/blog/${post.slug}/`} class="mt-5 inline-flex text-sm font-bold text-neutral-950 underline decoration-neutral-300 underline-offset-4 transition hover:decoration-neutral-950">Baca selengkapnya</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer slot="footer" />
</BaseLayout>
