---
import { WHATSAPP_MESSAGES } from '../utils/constants.js';
import WhatsAppButton from './WhatsAppButton.astro';

export interface Props {
  title?: string;
  description?: string;
  primaryText?: string;
  primaryLink?: string;
  secondaryText?: string;
  secondaryLink?: string;
  backgroundImage?: string;
  variant?: 'default' | 'gradient' | 'image' | 'minimal';
  size?: 'sm' | 'md' | 'lg';
  whatsappMessage?: string;
}

const {
  title = 'Mari buat produk yang benar-benar siap diwujudkan.',
  description = 'Kirim ukuran, foto lokasi, atau referensi desain. Tim kami akan membantu membaca kebutuhan material, teknologi, dan prosesnya.',
  primaryText = 'Konsultasi proyek',
  secondaryText = 'Kirim brief lengkap',
  secondaryLink = '/contact/',
  backgroundImage,
  variant = 'default',
  size = 'md',
  whatsappMessage = WHATSAPP_MESSAGES.productDefault
} = Astro.props;

const isDark = variant === 'minimal' || variant === 'image';
const sizeClass = size === 'sm' ? 'py-16 md:py-20' : size === 'lg' ? 'py-24 md:py-36' : 'py-20 md:py-28';
---

<section class:list={['relative overflow-hidden border-y', sizeClass, isDark ? 'border-white/10 bg-surface text-text-main' : 'border-black/10 bg-paper text-ink']}>
  {variant === 'image' && backgroundImage && (
    <div class="absolute inset-0">
      <img src={backgroundImage} alt="" class="h-full w-full object-cover opacity-20" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-background/75"></div>
    </div>
  )}
  <div class="pointer-events-none absolute inset-0 metal-grain" aria-hidden="true"></div>

  <div class="container-custom relative" data-reveal>
    <div class="grid items-end gap-10 lg:grid-cols-[1fr_auto] lg:gap-16">
      <div class="max-w-5xl">
        <p class:list={['eyebrow mb-7', isDark ? 'text-text-secondary' : 'text-ink/55']}>Mulai percakapan</p>
        <h2 class:list={['font-display text-[clamp(2.8rem,6vw,6.8rem)] font-semibold leading-[0.91] tracking-[-0.06em]', isDark ? 'text-text-main' : 'text-ink']}>{title}</h2>
        <p class:list={['mt-7 max-w-2xl text-base leading-relaxed md:text-lg', isDark ? 'text-text-secondary' : 'text-ink/65']}>{description}</p>
      </div>

      <div class="flex min-w-[220px] flex-col gap-3 lg:pb-2">
        <WhatsAppButton
          message={whatsappMessage}
          label={primaryText}
          className="justify-center rounded-full bg-accent px-6 py-4 text-text-main hover:bg-accent-orange"
          source="cta_section"
        />
        <a href={secondaryLink} class:list={['inline-flex min-h-14 items-center justify-center gap-3 rounded-full border px-6 py-4 text-sm font-bold transition-colors', isDark ? 'border-white/25 text-text-main hover:bg-text-main hover:text-background' : 'border-black/25 text-ink hover:bg-ink hover:text-paper']}>
          {secondaryText}
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m-5-5 5 5-5 5" /></svg>
        </a>
      </div>
    </div>

    <div class:list={['mt-14 flex flex-wrap gap-x-7 gap-y-3 border-t pt-6 font-mono text-[0.6rem] uppercase tracking-[0.13em]', isDark ? 'border-white/10 text-text-secondary' : 'border-black/15 text-ink/55']}>
      <span>Review brief awal</span>
      <span>Rekomendasi material</span>
      <span>Estimasi sesuai lingkup</span>
    </div>
  </div>
</section>
