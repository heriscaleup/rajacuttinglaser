---
import BaseLayout from '../../components/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { getCollection, type CollectionEntry } from 'astro:content';
import { generateBlogPostSchema, generateBreadcrumbSchema } from '../../utils/seo';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return allPosts.filter(post => !post.data.draft).map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post }: { post: CollectionEntry<'blog'> } = Astro.props;
const { Content, headings } = await post.render();
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === post.data.category && p.slug !== post.slug && !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const siteName = 'Raja Cutting Laser';
const accent = 'text-blue-700';
const fallbackImage = '/images/metal.webp';
function resolveImage(image) {
  if (!image) return fallbackImage;
  if (image.startsWith('http://') || image.startsWith('https://')) return image;
  const normalized = image.startsWith('/') ? image : `/${image}`;
  return existsSync(join(process.cwd(), 'public', normalized.slice(1))) ? normalized : fallbackImage;
}

const jsonLd = generateBlogPostSchema({ title: post.data.title, excerpt: post.data.description, image: resolveImage(post.data.image), publishDate: post.data.pubDate.toISOString(), slug: post.slug });
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Beranda', url: '/' },
  { name: 'Blog', url: '/blog/' },
  { name: post.data.title, url: `/blog/${post.slug}/` }
]);
---

<BaseLayout
  title={`${post.data.title} | Blog ${siteName}`}
  description={post.data.description}
  keywords={`${post.data.title.toLowerCase()}, ${post.data.category.toLowerCase()}`}
  image={resolveImage(post.data.image)}
  type="article"
  jsonLd={[jsonLd, breadcrumbSchema]}
>
  <Header slot="header" />

  <main class="bg-[#fbfaf7] text-[#171717]">
    <article class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[minmax(0,1fr)_300px] lg:px-8 lg:py-20">
      <div class="min-w-0">
        <nav class="mb-10 text-sm text-neutral-500" aria-label="Breadcrumb">
          <a href="/" class="font-semibold hover:text-neutral-950">Beranda</a>
          <span class="mx-2">/</span>
          <a href="/blog/" class="font-semibold hover:text-neutral-950">Blog</a>
        </nav>

        <header class="border-b border-black/10 pb-8">
          <div class="mb-5 flex flex-wrap items-center gap-3 text-sm text-neutral-500">
            <span class={`font-black uppercase tracking-[0.18em] ${accent}`}>{post.data.category}</span>
            <span>•</span>
            <time>{new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <span>•</span>
            <span>{post.data.readTime}</span>
          </div>
          <h1 class="max-w-4xl text-4xl font-black leading-[1.02] tracking-[-0.055em] text-neutral-950 sm:text-6xl lg:text-7xl">{post.data.title}</h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-neutral-600 sm:text-xl">{post.data.description}</p>
          <div class="mt-7 flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-full border border-black/10 bg-white text-lg font-black text-neutral-900">{siteName.charAt(0)}</div>
            <div>
              <p class="text-sm font-bold text-neutral-950">{post.data.author || siteName}</p>
              <p class="text-xs text-neutral-500">Tim editorial {siteName}</p>
            </div>
          </div>
        </header>

        <figure class="my-10 overflow-hidden rounded-[2rem] border border-black/10 bg-neutral-100">
          <img
            src={resolveImage(post.data.image)}
            alt={post.data.title}
            class="aspect-[16/9] w-full object-cover"
            loading="eager"
            onerror={`this.onerror=null;this.src='${fallbackImage}';`}
          />
        </figure>

        {toc.length > 0 && (
          <details class="mb-10 rounded-3xl border border-black/10 bg-white p-5 lg:hidden">
            <summary class="cursor-pointer text-sm font-black text-neutral-950">Daftar Isi</summary>
            <ol class="mt-4 space-y-3 text-sm text-neutral-600">
              {toc.map((heading) => <li class={heading.depth === 3 ? 'ml-4' : ''}><a href={`#${heading.slug}`} class="hover:text-neutral-950">{heading.text}</a></li>)}
            </ol>
          </details>
        )}

        <div class="article-prose prose prose-lg max-w-none prose-headings:font-black prose-headings:tracking-[-0.035em] prose-headings:text-neutral-950 prose-p:leading-8 prose-p:text-neutral-700 prose-a:font-bold prose-a:text-neutral-950 prose-strong:text-neutral-950 prose-li:text-neutral-700">
          <Content />
        </div>
      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          {toc.length > 0 && (
            <div class="rounded-3xl border border-black/10 bg-white/80 p-6 backdrop-blur">
              <h2 class="mb-4 text-lg font-black text-neutral-950">Daftar Isi</h2>
              <ol class="space-y-3 text-sm leading-6 text-neutral-600">
                {toc.map((heading) => <li class={heading.depth === 3 ? 'ml-4' : ''}><a href={`#${heading.slug}`} class="hover:text-neutral-950">{heading.text}</a></li>)}
              </ol>
            </div>
          )}
          <div class="rounded-3xl border border-black/10 bg-white p-6">
            <h2 class="text-lg font-black text-neutral-950">Butuh Konsultasi?</h2>
            <p class="mt-3 text-sm leading-6 text-neutral-600">Diskusikan kebutuhan material, desain, estimasi biaya, dan produksi dengan tim kami.</p>
            <a href={'https://api.whatsapp.com/send?phone=6285165693179&text=Halo%20Raja%20Cutting%20Laser%2C%20saya%20ingin%20konsultasi'} target="_blank" rel="noopener noreferrer" class={`mt-5 inline-flex w-full justify-center rounded-full px-5 py-3 text-sm font-black text-white ${'bg-blue-700 hover:bg-blue-800'}`}>Konsultasi Sekarang</a>
          </div>
        </div>
      </aside>
    </article>

    {relatedPosts.length > 0 && (
      <section class="border-t border-black/10 py-14">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
          <div class="mb-8 flex items-end justify-between border-b border-black/10 pb-5">
            <h2 class="text-2xl font-black tracking-[-0.03em] text-neutral-950">Artikel Terkait</h2>
            <a href="/blog/" class="text-sm font-bold text-neutral-600 hover:text-neutral-950">Lihat semua →</a>
          </div>
          <div class="grid gap-7 md:grid-cols-3">
            {relatedPosts.map((relatedPost) => (
              <article class="group border-b border-black/10 pb-7">
                <a href={`/blog/${relatedPost.slug}/`} class="block overflow-hidden rounded-3xl border border-black/10 bg-neutral-100">
                  <img src={resolveImage(relatedPost.data.image)} alt={relatedPost.data.title} class="aspect-[16/10] w-full object-cover transition duration-700 group-hover:scale-[1.04]" loading="lazy" onerror={`this.onerror=null;this.src='${fallbackImage}';`} />
                </a>
                <p class={`mt-5 text-xs font-black uppercase tracking-[0.16em] ${accent}`}>{relatedPost.data.category}</p>
                <h3 class="mt-2 text-lg font-black leading-tight text-neutral-950"><a href={`/blog/${relatedPost.slug}/`} class="group-hover:text-neutral-600">{relatedPost.data.title}</a></h3>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer slot="footer" />
</BaseLayout>
