---
import BaseLayout from '../components/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { MATERIALS, SERVICES, SITE_CONFIG } from '../utils/constants.js';
import OptimizedImage from '../components/OptimizedImage.astro';
import { generateMetaTags, generateServiceSchema, generateBreadcrumbSchema } from '../utils/seo.ts';

const material = MATERIALS.find(m => m.id === 'metal');
if (!material) throw new Error('Material metal not found');

const recommendedService = SERVICES.find(s => s.id === 'laser-fiber');
if (!recommendedService) throw new Error('Recommended service not found');

// Generate Meta Tags
const metaTags = generateMetaTags({
  title: "Cutting Stainless Steel & Metal - SS304, SS316 | Raja Cutting Laser",
  description: "Jasa cutting stainless steel & metal dengan laser fiber. Grade SS304, SS316, SS201. Ketebalan 0.5-20mm, toleransi ±0.05mm. Finishing mirror, hairline. Hubungi sekarang!",
  keywords: material.keywords,
  url: `/material-metal/`,
  type: "article",
  image: material.image,
  publishedTime: "2025-01-01T00:00:00Z", 
  modifiedTime: "2025-01-01T00:00:00Z",
  author: SITE_CONFIG.author
});

// Generate structured data
const serviceSchema = recommendedService ? generateServiceSchema(recommendedService) : null;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Beranda', url: '/' },
  { name: 'Material', url: '/#materials' },
  { name: material.name, url: `/material-metal/` }
]);

// Combine schemas for jsonLd
const jsonLd = [serviceSchema, breadcrumbSchema].filter(Boolean);

---

<BaseLayout
  title={metaTags.title}
  description={metaTags.description}
  keywords={metaTags.keywords}
  url={metaTags.canonical}
  jsonLd={jsonLd}
  type="article"
>
  <Header slot="header" />
  
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-background via-container to-background text-text-main py-20">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl lg:text-5xl font-bold mb-6">
            Jasa Cutting Metal & Stainless Steel dengan Laser Fiber
          </h1>
          <p class="text-xl mb-8 text-text-secondary">
            {material.description}
          </p>
          <div class="flex flex-wrap gap-4">
            <a 
              href={`https://api.whatsapp.com/send?phone=6285165693179&text=Halo%20raja%20cutting%20laser,%20saya%20ingin%20konsultasi%20dong%20tentang%20jasa%20laser%20cutting%20${material.name}.%20Bisa%20konsultasi?`}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-button hover:bg-highlight text-white hover:text-button px-8 py-3 rounded-lg font-semibold transition-colors"
            >
              Konsultasi Gratis
            </a>
            <a 
              href="contact" 
              class="border-2 border-button text-button hover:bg-button hover:text-white px-8 py-3 rounded-lg font-semibold transition-colors"
            >
              Request Quote
            </a>
          </div>
        </div>
        <div class="relative">
          <OptimizedImage 
            src={material.image} 
            alt={`Sample ${material.name}`}
            className="w-full h-96 object-cover rounded-lg shadow-2xl"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Material Characteristics -->
  <section class="py-16 bg-container">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-text-main mb-4">
          Karakteristik {material.name}
        </h2>
        <p class="text-xl text-text-secondary max-w-3xl mx-auto">
          Material metal premium dengan kekuatan tinggi dan ketahanan korosi superior
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-background p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-container rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-text-main">Anti Karat</h3>
          <p class="text-text-secondary">Tahan korosi dan karat untuk penggunaan jangka panjang di berbagai kondisi</p>
        </div>

        <div class="bg-background p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-container rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-text-main">Kekuatan Tinggi</h3>
          <p class="text-text-secondary">Struktur molekul yang kuat memberikan daya tahan maksimal untuk aplikasi industri</p>
        </div>

        <div class="bg-background p-6 rounded-lg shadow-md">
          <div class="w-12 h-12 bg-container rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2 text-text-main">Presisi Tinggi</h3>
          <p class="text-text-secondary">Hasil cutting dengan toleransi ketat untuk aplikasi presisi tinggi</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Specifications -->
  <section class="py-16 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-text-main mb-6">
            Spesifikasi Teknis
          </h2>
          <div class="space-y-4">
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Ketebalan</span>
              <span class="text-text-secondary">{material.thickness}</span>
            </div>
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Grade Tersedia</span>
              <span class="text-text-secondary">SS304, SS316, SS201</span>
            </div>
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Toleransi Cutting</span>
              <span class="text-text-secondary">±0.05 mm</span>
            </div>
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Finishing</span>
              <span class="text-text-secondary">Mirror, Hairline, Brushed</span>
            </div>
            <div class="flex justify-between py-3 border-b border-primary">
              <span class="font-medium text-text-main">Heat Treatment</span>
              <span class="text-text-secondary">Available</span>
            </div>
          </div>
        </div>
        <div class="bg-container p-8 rounded-lg">
          <h3 class="text-2xl font-bold text-text-main mb-6">Contoh Aplikasi</h3>
          <div class="grid grid-cols-2 gap-4">
            <OptimizedImage src="/images/stainlesssteel (1).webp" alt="Contoh Aplikasi 1" className="w-full h-40 object-cover rounded-lg shadow-md" />
            <OptimizedImage src="/images/stainlesssteel (2).webp" alt="Contoh Aplikasi 2" className="w-full h-40 object-cover rounded-lg shadow-md" />
            <OptimizedImage src="/images/stainlesssteel (3).webp" alt="Contoh Aplikasi 3" className="w-full h-40 object-cover rounded-lg shadow-md" />
            <OptimizedImage src="/images/stainlesssteel (4).webp" alt="Contoh Aplikasi 4" className="w-full h-40 object-cover rounded-lg shadow-md" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recommended Service -->
  <section class="py-16 bg-container">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-text-main mb-4">
          Mesin Rekomendasi untuk {material.name}
        </h2>
        <p class="text-xl text-text-secondary">
          Teknologi laser fiber untuk cutting metal dengan presisi maksimal
        </p>
      </div>

      <div class="bg-background rounded-lg shadow-lg p-8">
        <div class="grid lg:grid-cols-2 gap-8 items-center">
          <div>
            <h3 class="text-2xl font-bold text-text-main mb-4">
              {recommendedService.name}
            </h3>
            <p class="text-text-secondary mb-6">
              {recommendedService.description}
            </p>
            <div class="space-y-3">
              {recommendedService.features.map((feature) => (
                <div class="flex items-center space-x-3">
                  <svg class="w-5 h-5 text-button" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-text-secondary">{feature}</span>
                </div>
              ))}
            </div>
            <div class="mt-6">
              <span class="text-2xl font-bold text-button">Hubungi untuk harga</span>
            </div>
          </div>
          <div>
            <OptimizedImage 
              src={recommendedService.image} 
              alt={recommendedService.name}
              className="w-full h-64 object-cover rounded-lg"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>